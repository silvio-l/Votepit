{% extends 'base.twig' %}

{% block title %}Anmelden · Votepit{% endblock %}

{% block content %}
<section class="vp-card">
    <h1 class="vp-h1">Anmelden</h1>
    <p class="vp-lead">Gib deine E-Mail-Adresse ein. Wir schicken dir einen Magic-Link.</p>
    <form method="POST" action="/login">
        <input type="hidden" name="_csrf" value="{{ csrf_token }}">
        {% if return_to %}<input type="hidden" name="r" value="{{ return_to }}">{% endif %}
        <label class="vp-label" for="email">E-Mail-Adresse</label>
        <input class="vp-input" type="email" id="email" name="email" required autocomplete="email" autofocus placeholder="du@example.com">
        <button class="vp-btn" type="submit">Magic-Link senden</button>
    </form>
</section>
{% endblock %}

{% block footer %}
<footer class="vp-footer">Votepit · Passwortlos anmelden</footer>
{% endblock %}
