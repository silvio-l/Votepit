{% extends 'base.twig' %}

{% block title %}Moderation — {{ board_name }}{% endblock %}

{% block content %}
<h1 class="vp-h1">Moderation</h1>
<p class="vp-lead">Board: {{ board_name }} ({{ board_slug }})</p>

{% if saved|default(false) %}
<p class="vp-lead">Gespeichert.</p>
{% endif %}

<form method="post" action="/admin/boards/{{ board_slug }}/moderation">
    <input type="hidden" name="_csrf" value="{{ csrf_token }}">
    <input type="hidden" name="action" value="toggle">

    <label class="vp-label" for="moderation_enabled">Wortfilter</label>
    <label style="display:flex;align-items:center;gap:.5rem;margin-bottom:1rem;">
        <input type="checkbox" id="moderation_enabled" name="moderation_enabled" value="1"
               {% if moderation_enabled %}checked{% endif %}>
        Wortfilter aktiviert
    </label>

    <button class="vp-btn" type="submit">Toggle speichern</button>
</form>

<hr style="margin:2rem 0;">

<h2 class="vp-h2" style="font-size:1.1rem;margin-bottom:1rem;">Board-eigene Blocklist</h2>

{% if words|length > 0 %}
<ul style="list-style:none;padding:0;margin-bottom:1rem;">
    {% for entry in words %}
    <li style="display:flex;align-items:center;gap:1rem;margin-bottom:.5rem;">
        <span>{{ entry.word }}</span>
        <form method="post" action="/admin/boards/{{ board_slug }}/moderation" style="margin:0;">
            <input type="hidden" name="_csrf" value="{{ csrf_token }}">
            <input type="hidden" name="action" value="remove">
            <input type="hidden" name="word_id" value="{{ entry.id }}">
            <button class="vp-btn" type="submit"
                    style="padding:.2rem .6rem;font-size:.85rem;">Entfernen</button>
        </form>
    </li>
    {% endfor %}
</ul>
{% else %}
<p class="vp-lead" style="font-size:.9rem;">Keine eigenen Wörter gespeichert.</p>
{% endif %}

<form method="post" action="/admin/boards/{{ board_slug }}/moderation">
    <input type="hidden" name="_csrf" value="{{ csrf_token }}">
    <input type="hidden" name="action" value="add">

    <label class="vp-label" for="new_word">Wort hinzufügen (Plaintext, max. 200 Zeichen)</label>
    <input class="vp-input" type="text" id="new_word" name="new_word"
           value="{{ new_word|default('') }}" placeholder="z. B. spam" maxlength="200" autocomplete="off">

    {% if word_error|default('') %}
    <p style="color:var(--vp-danger,#dc2626);font-size:.875rem;margin:.25rem 0 0;">{{ word_error }}</p>
    {% endif %}

    <button class="vp-btn" type="submit" style="margin-top:.75rem;">Wort hinzufügen</button>
</form>
{% endblock %}
