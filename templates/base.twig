{#
  base.twig — Votepit Base-Layout (Issue 07, Sprint 2)

  ┌─ Marken-Tokens (pro Board in Issue 08 überschreibbar) ──────────────────┐
  │ --vp-primary            Brand-Primärfarbe (Ink/Schwarz Standard)         │
  │ --vp-secondary          Brand-Sekundär-/Akzentfarbe                      │
  │ --vp-primary-contrast   Text auf --vp-primary                            │
  │ --vp-primary-glow       Dezenter Glow um primäre Elemente                │
  │ --vp-bg                 Seitenhintergrund (warm-neutral)                  │
  │ --vp-surface            Frosted-Glass-Karten-Fläche                      │
  │ --vp-surface-border     Glasrand                                          │
  │ --vp-border             Subtile Trennlinie                                │
  │ --vp-radius             Squircle-Näherung (Karte)                         │
  │ --vp-radius-sm          Squircle-Näherung (kleine Elemente)               │
  │ --vp-text               Primärtext                                        │
  │ --vp-text-muted         Sekundärtext                                      │
  └────────────────────────────────────────────────────────────────────────────┘

  ┌─ Semantische Tokens (NICHT Board-überschreibbar) ──────────────────────┐
  │ --vp-vote-up / --vp-vote-up-bg      Up-Vote (Grün)                      │
  │ --vp-vote-down / --vp-vote-down-bg  Down-Vote (Vermillion)              │
  │ --vp-consensus-high                 Hoher Konsens (Grün)                │
  │ --vp-consensus-low                  Umstritten (Vermillion)             │
  │ --vp-status-open/planned/…          Idea-Status-Farben                  │
  │ --vp-font-sans/head/mono            Typografie-Stack                    │
  └────────────────────────────────────────────────────────────────────────────┘

  Issue 08 überschreibt ausschließlich die Marken-Tokens per Inline-Custom-
  Properties am <html>-Element. Semantische Tokens sind bewusst nicht
  überschreibbar — Up/Down/Konsens-Lesbarkeit ist brand-unabhängig.
#}
<!DOCTYPE html>
{#
  brand_style: vom Server (BrandingValidator::inlineStyle) erzeugter String aus
  ausschließlich validierten Marken-Token-Overrides (--vp-primary/--vp-secondary).
  Inline am <html> gewinnt per Kaskade gegen die :root-Defaults; ist er leer,
  greift das Default-Theme. Semantische Tokens werden hier NIE überschrieben.
#}
<html lang="de"{% if brand_style|default('') is not empty %} style="{{ brand_style }}"{% endif %}>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Votepit{% endblock %}</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <link rel="icon" href="/favicon-32.png" sizes="32x32" type="image/png">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <style>
        /* ── Self-hosted Webfonts (Light Modern: Archivo/Inter/JetBrains Mono) ── */
        @font-face { font-family: "Archivo"; font-style: normal; font-weight: 600; font-display: swap; src: url("/assets/fonts/archivo-600.woff2") format("woff2"); }
        @font-face { font-family: "Archivo"; font-style: normal; font-weight: 700; font-display: swap; src: url("/assets/fonts/archivo-700.woff2") format("woff2"); }
        @font-face { font-family: "Archivo"; font-style: normal; font-weight: 800; font-display: swap; src: url("/assets/fonts/archivo-800.woff2") format("woff2"); }
        @font-face { font-family: "Inter"; font-style: normal; font-weight: 400; font-display: swap; src: url("/assets/fonts/inter-400.woff2") format("woff2"); }
        @font-face { font-family: "Inter"; font-style: normal; font-weight: 500; font-display: swap; src: url("/assets/fonts/inter-500.woff2") format("woff2"); }
        @font-face { font-family: "Inter"; font-style: normal; font-weight: 600; font-display: swap; src: url("/assets/fonts/inter-600.woff2") format("woff2"); }
        @font-face { font-family: "JetBrains Mono"; font-style: normal; font-weight: 600; font-display: swap; src: url("/assets/fonts/jbmono-600.woff2") format("woff2"); }
        @font-face { font-family: "JetBrains Mono"; font-style: normal; font-weight: 700; font-display: swap; src: url("/assets/fonts/jbmono-700.woff2") format("woff2"); }

        /* ── Marken-Tokens (Board-überschreibbar via Issue 08) ──────────── */
        :root {
            --vp-primary:          #15161A;
            --vp-secondary:        #0E5C6E;
            --vp-primary-contrast: #ffffff;
            --vp-primary-glow:     rgba(21, 22, 26, 0.12);
            --vp-bg:               #F6F6F3;
            --vp-surface:          rgba(255, 255, 255, 0.72);   /* color/surface-card */
            --vp-surface-frost:    rgba(255, 255, 255, 0.66);   /* color/surface-card-frost */
            --vp-surface-border:   rgba(255, 255, 255, 0.55);
            --vp-border:           #e6e6e0;                     /* color/border-subtle (solid) */
            --vp-radius:           16px;                        /* radius/lg */
            --vp-radius-md:        11px;                        /* radius/md */
            --vp-radius-sm:        10px;
            --vp-accent:           #1FA890;                     /* brand/primary (Board-überschreibbar) */
            --vp-accent-contrast:  #ffffff;
            --vp-text:             #15161A;                     /* text/primary */
            --vp-text-muted:       #565A62;                     /* text/secondary */
            --vp-text-faint:       #979BA3;                     /* text/muted */
            --vp-surface-subtle:   #f1f1ee;
            --vp-surface-hover:    rgba(21, 22, 26, .05);
            --vp-code-text:        #e9e9e7;
            --vp-row-shadow:       0 8px 24px -6px rgba(20, 23, 26, 0.07);
        }

        /* ── Semantische Tokens (NICHT Board-überschreibbar) ────────────── */
        :root {
            /* Voting — Grün (Up) / Vermillion (Down) */
            --vp-vote-up:            #0E9466;
            --vp-vote-up-bg:         #dcfce7;
            --vp-vote-up-glow:       rgba(14, 148, 102, 0.35);
            --vp-vote-down:          #D8503C;
            --vp-vote-down-bg:       #fee2e2;

            /* Konsens */
            --vp-consensus-high:     #0E9466;
            --vp-consensus-low:      #D8503C;

            /* Idea-Status */
            --vp-status-open:        #979BA3;
            --vp-status-planned:     #2E73D6;
            --vp-status-in-progress: #C0821A;
            --vp-status-done:        #0E9466;
            --vp-status-declined:    #D8503C;

            /* Typografie (Archivo Headlines + Inter Body + JetBrains Mono Zahlen) */
            --vp-font-sans: "Inter", ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            --vp-font-head: "Archivo", "Inter", ui-sans-serif, system-ui, sans-serif;
            --vp-font-mono: "JetBrains Mono", ui-monospace, "Cascadia Code", "Fira Code", monospace;
        }

        /* ── Reset ───────────────────────────────────────────────────────── */
        *, *::before, *::after { box-sizing: border-box; }

        body {
            margin: 0;
            min-height: 100vh;
            font-family: var(--vp-font-sans);
            color: var(--vp-text);
            /* Hintergrund-Verlauf 1:1 zur Landing: grüner Glow oben-rechts + warmer Creme-Ton unten-links */
            background:
                radial-gradient(1250px 660px at 64% -14%, rgba(14, 148, 102, 0.18), rgba(14, 148, 102, 0) 62%),
                radial-gradient(1050px 780px at 1% 80%, rgba(196, 150, 82, 0.08), rgba(196, 150, 82, 0) 60%),
                var(--vp-bg);
            background-repeat: no-repeat;
            background-attachment: fixed;
            line-height: 1.5;
            -webkit-font-smoothing: antialiased;
            overflow-x: hidden;
        }

        /* ── Karte (Frosted-Glass + Squircle-Näherung) ───────────────────── */
        .vp-card {
            background: var(--vp-surface);
            border: 1px solid var(--vp-surface-border);
            border-radius: var(--vp-radius);
            padding: 2rem 2.25rem;
            box-shadow:
                0 0 0 1px var(--vp-border),
                0 4px 24px var(--vp-primary-glow),
                0 1px 3px rgba(21, 22, 26, .06);
            backdrop-filter: blur(16px) saturate(1.2);
            -webkit-backdrop-filter: blur(16px) saturate(1.2);
        }

        /* ── Primär-Button ───────────────────────────────────────────────── */
        .vp-btn {
            display: inline-block;
            width: 100%;
            margin-top: 1rem;
            padding: .65rem 1rem;
            background: var(--vp-primary);
            color: var(--vp-primary-contrast);
            border: none;
            border-radius: var(--vp-radius-sm);
            font-family: var(--vp-font-sans);
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: opacity .15s;
            text-align: center;
        }
        .vp-btn:hover { opacity: .85; }

        /* ── Eingabefeld ─────────────────────────────────────────────────── */
        .vp-input {
            width: 100%;
            padding: .6rem .8rem;
            border: 1px solid var(--vp-border);
            border-radius: var(--vp-radius-sm);
            font-family: var(--vp-font-sans);
            font-size: 1rem;
            color: var(--vp-text);
            background: var(--vp-surface);
            outline: none;
            transition: border-color .15s;
        }
        .vp-input:focus { border-color: var(--vp-primary); }

        /* ── Typografie-Helfer ───────────────────────────────────────────── */
        .vp-wrap   { max-width: 460px; margin: 12vh auto; padding: 2.5rem 1.5rem; }
        .vp-h1     { margin: 0 0 .25rem; font-family: var(--vp-font-head); font-size: 1.5rem; letter-spacing: -.02em; }
        .vp-lead   { color: var(--vp-text-muted); margin: .5rem 0 1.5rem; font-size: .95rem; }
        .vp-label  { display: block; font-size: .875rem; font-weight: 500; margin-bottom: .4rem; }
        .vp-footer { margin-top: 1.5rem; color: var(--vp-text-muted); font-size: .8rem; text-align: center; }
        .vp-link   { color: var(--vp-primary); }
        .vp-icon   { font-size: 2rem; margin-bottom: .75rem; display: block; }

        /* Votepit-Wortbildmarke (Default-Markenzeichen, wenn kein Board-Logo) */
        .vp-brand      { display: inline-flex; align-items: center; gap: .04em; margin-bottom: 1.25rem;
                         text-decoration: none; font-family: var(--vp-font-head); font-weight: 800;
                         letter-spacing: -.02em; font-size: 1.6rem; line-height: 1; }
        .vp-brand-icon { height: 1.5em; width: auto; display: block; margin-right: .02em; }
        .vp-brand-word { color: var(--vp-text); }
        .vp-brand-pit  { color: var(--vp-vote-down); }
        .vp-logo       { max-height: 2.5rem; width: auto; display: block; margin-bottom: 1.25rem; }

        /* ── Persistente Attribution (nicht board-überschreibbar) ────────── */
        .vp-attr { margin: 1rem 0 0; color: var(--vp-text-muted); font-size: .75rem; text-align: center; opacity: .7; }
        .vp-attr a { color: inherit; text-decoration: underline; text-underline-offset: 2px; }

        /* ════════════════════════════════════════════════════════════════════
           App-Komponenten — 1:1 Figma Variante F, Referenz-Screen 80:33
           Maße/Tokens direkt aus den Figma-Komponenten (74:87, 69:85, 67:45, …).
           ════════════════════════════════════════════════════════════════════ */

        /* Marken-Backdrop (1:1 zur Landing): zwei angeschnittene Votepit-Hexagone,
           sehr geringe Deckkraft, sanfter Assemble/Dissolve-Loop, reduced-motion-sicher. */
        .vp-backdrop { position: fixed; inset: 0; overflow: hidden; pointer-events: none; z-index: 0; }
        .vp-hex { position: absolute; }
        .vp-hex--tr { top: -150px; right: -120px; opacity: .05; }
        .vp-hex--bl { bottom: -140px; left: -130px; opacity: .038; }
        @media (prefers-reduced-motion: no-preference) {
            .vp-h { opacity: 0; transform-box: fill-box; transform-origin: 50% 50%; }
            .vp-h--top  { animation: vp-cy-down 20s ease-in-out 0s   infinite; }
            .vp-h--bot  { animation: vp-cy-up   20s ease-in-out .6s  infinite; }
            .vp-h--mid  { animation: vp-cy-pop  20s ease-in-out 1.0s infinite; }
            .vp-h--dark { animation: vp-cy-pop  20s ease-in-out 1.3s infinite; }
            .vp-hex--bl .vp-h--top  { animation-delay: 10s; }
            .vp-hex--bl .vp-h--bot  { animation-delay: 10.6s; }
            .vp-hex--bl .vp-h--mid  { animation-delay: 11s; }
            .vp-hex--bl .vp-h--dark { animation-delay: 11.3s; }
            @keyframes vp-cy-down { 0%{opacity:0;transform:translate(-30px,-98px) scale(.95);} 14%{opacity:1;transform:none;} 64%{opacity:1;transform:none;} 84%,100%{opacity:0;transform:translate(-30px,-98px) scale(.95);} }
            @keyframes vp-cy-up   { 0%{opacity:0;transform:translate(30px,98px) scale(.95);} 14%{opacity:1;transform:none;} 64%{opacity:1;transform:none;} 84%,100%{opacity:0;transform:translate(30px,98px) scale(.95);} }
            @keyframes vp-cy-pop  { 0%{opacity:0;transform:scale(.08);} 14%{opacity:1;transform:none;} 64%{opacity:1;transform:none;} 84%,100%{opacity:0;transform:scale(.08);} }
            .vp-hex-g { transform-box: fill-box; transform-origin: 50% 50%; animation: vp-h-float 26s ease-in-out infinite; }
            .vp-hex--bl .vp-hex-g { animation-duration: 32s; animation-direction: reverse; }
            @keyframes vp-h-float { 0%,100%{transform:translateY(0) rotate(0deg);} 50%{transform:translateY(-16px) rotate(1.9deg);} }
        }

        /* Web-Layout: Hintergrund füllt den Viewport, Inhalt fluid zentriert.
           Die Figma-Komponenten bleiben 1:1 — nur die Seitenkomposition ist web-nativ. */
        .vp-shell { position: relative; z-index: 1; }
        .vp-container { max-width: 1160px; margin: 0 auto; padding-left: clamp(16px, 4vw, 48px); padding-right: clamp(16px, 4vw, 48px); }

        /* ── Header (Figma 66:32) — full-bleed, sticky ────────────────────── */
        .vp-header { position: sticky; top: 0; z-index: 20; width: 100%; background: var(--vp-surface-frost); border-bottom: 1px solid var(--vp-border); backdrop-filter: blur(14px) saturate(1.18); -webkit-backdrop-filter: blur(14px) saturate(1.18); }
        .vp-header-inner { max-width: 1160px; margin: 0 auto; padding: 14px clamp(16px, 4vw, 48px); display: flex; align-items: center; justify-content: space-between; gap: 1rem; }
        .vp-logo   { display: inline-flex; align-items: center; gap: 3px; text-decoration: none; height: 30px; }
        .vp-logo img { width: 30px; height: 30px; display: block; }
        .vp-logo-word { display: inline-flex; align-items: center; height: 30px; font-family: var(--vp-font-head); font-weight: 800; font-size: 24px; letter-spacing: -.6px; line-height: 1; color: var(--vp-text); }
        .vp-logo-word .p { color: var(--vp-vote-down); }
        .vp-logo-ctx { display: inline-flex; align-items: center; gap: 11px; text-decoration: none; height: 30px; }
        .vp-logo-avatar { width: 30px; height: 30px; border-radius: 9px; background: var(--vp-primary); color: var(--vp-primary-contrast); display: inline-flex; align-items: center; justify-content: center; font-family: var(--vp-font-head); font-weight: 700; font-size: 15px; line-height: 1; }
        .vp-logo-ctx-name { display: inline-flex; align-items: center; height: 30px; font-family: var(--vp-font-head); font-weight: 600; font-size: 16px; letter-spacing: -.01em; color: var(--vp-text); }
        .vp-nav    { display: inline-flex; align-items: center; gap: 22px; }
        .vp-nav-link { font-family: var(--vp-font-sans); font-weight: 500; font-size: 14px; color: var(--vp-text-muted); text-decoration: none; }
        .vp-nav-link:hover { color: var(--vp-text); }

        /* ── Button (Figma 59:38) ─────────────────────────────────────────── */
        .vp-btn2 { display: inline-flex; align-items: center; justify-content: center; padding: 12px 24px; border-radius: 11px; font-family: var(--vp-font-sans); font-weight: 600; font-size: 14px; line-height: 1.1; text-decoration: none; cursor: pointer; border: 1px solid transparent; transition: opacity .15s, border-color .15s, background .15s; }
        .vp-btn2--primary   { background: var(--vp-primary); color: var(--vp-primary-contrast); box-shadow: 0 4px 12px -2px rgba(20,23,26,.18); }
        .vp-btn2--primary:hover { opacity: .9; }
        .vp-btn2--secondary { background: transparent; color: var(--vp-text); border-color: var(--vp-border); }
        .vp-btn2--secondary:hover { border-color: var(--vp-text); }
        .vp-btn2--ghost     { background: transparent; color: var(--vp-text); }
        .vp-btn2--ghost:hover { color: var(--vp-text-muted); }
        .vp-btn2--sm { padding: 9px 16px; border-radius: 10px; font-weight: 600; }

        /* ── Hero (Figma 81:57) ───────────────────────────────────────────── */
        .vp-hero      { padding: 48px 0 0; display: flex; flex-direction: column; gap: 16px; align-items: flex-start; }
        .vp-hero-title { margin: 0; font-family: var(--vp-font-head); font-weight: 700; font-size: clamp(30px, 5vw, 40px); line-height: 1.08; letter-spacing: -.02em; color: var(--vp-text); }
        .vp-hero-sub   { margin: 0; font-family: var(--vp-font-sans); font-weight: 400; font-size: 15px; line-height: 1.48; color: var(--vp-text-muted); max-width: 640px; }

        /* ── Filter-Chips (Figma 81:64) ───────────────────────────────────── */
        .vp-filter { padding: 24px 0 0; display: flex; flex-direction: column; gap: 16px; }
        .vp-chips  { display: flex; gap: 8px; flex-wrap: wrap; }
        .vp-chip   { display: inline-flex; align-items: center; padding: 6px 12px; border-radius: 999px; font-family: var(--vp-font-sans); font-weight: 500; font-size: 13px; text-decoration: none; color: var(--vp-text-faint); background: var(--vp-bg); border: 1px solid var(--vp-border); }
        .vp-chip:hover { color: var(--vp-text); }
        .vp-chip--active { background: var(--vp-accent); color: var(--vp-accent-contrast); border-color: transparent; }
        .vp-chip--active:hover { color: var(--vp-accent-contrast); opacity: .92; }

        /* ── SortTabs (Figma 67:45) ───────────────────────────────────────── */
        .vp-sorttabs { display: flex; gap: 3px; padding: 4px; border-radius: 11px; background: var(--vp-surface-frost); border: 1px solid var(--vp-border); box-shadow: var(--vp-row-shadow); align-self: stretch; }
        .vp-sorttab  { display: inline-flex; align-items: center; padding: 8px 15px; border-radius: 8px; font-family: var(--vp-font-sans); font-weight: 500; font-size: 13px; color: var(--vp-text-faint); border: 1px solid transparent; }
        .vp-sorttab--active { background: var(--vp-surface); border-color: var(--vp-border); color: var(--vp-text); font-weight: 600; }

        /* ── Vote-Control (Figma 71:69) ───────────────────────────────────── */
        .vp-vote   { display: flex; flex-direction: column; align-items: center; gap: 4px; width: 54px; flex-shrink: 0; }
        .vp-vote-btn { display: flex; align-items: center; justify-content: center; width: 100%; padding: 8px 0; border-radius: 11px; border: 1px solid var(--vp-border); background: var(--vp-surface); }
        .vp-vote-btn svg { width: 11px; height: 8px; display: block; color: var(--vp-text-faint); }
        .vp-vote-score { font-family: var(--vp-font-mono); font-weight: 700; font-size: 22px; line-height: 26px; color: var(--vp-text); }
        .vp-vote-score--neg { color: var(--vp-vote-down); }
        .vp-vote--up .vp-vote-up   { background: var(--vp-vote-up); border-color: transparent; box-shadow: 0 3px 13px var(--vp-vote-up-glow); }
        .vp-vote--up .vp-vote-up svg   { color: #fff; }
        .vp-vote--down .vp-vote-down { background: var(--vp-vote-down); border-color: transparent; box-shadow: 0 3px 13px rgba(216,80,60,.35); }
        .vp-vote--down .vp-vote-down svg { color: #fff; }
        .vp-vote--lg { width: 64px; }
        .vp-vote--lg .vp-vote-score { font-size: 28px; }

        /* ── StatusBadge Pill (Figma 61:47) ───────────────────────────────── */
        .vp-badge { display: inline-flex; align-items: center; gap: 4px; padding: 4px 8px; border-radius: 999px; background: var(--vp-surface-frost); }
        .vp-badge-dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }
        .vp-badge-label { font-family: var(--vp-font-sans); font-weight: 400; font-size: 12px; color: var(--vp-text-muted); white-space: nowrap; }
        .vp-badge-open        .vp-badge-dot { background: var(--vp-status-open); }
        .vp-badge-planned     .vp-badge-dot { background: var(--vp-status-planned); }
        .vp-badge-in_progress .vp-badge-dot { background: var(--vp-status-in-progress); }
        .vp-badge-done        .vp-badge-dot { background: var(--vp-status-done); }
        .vp-badge-declined    .vp-badge-dot { background: var(--vp-status-declined); }

        /* ── ConsensusBar (Figma 63:32) ───────────────────────────────────── */
        .vp-cons { display: flex; flex-direction: column; gap: 6px; width: 152px; }
        .vp-cons-head { display: flex; align-items: center; gap: 4px; }
        .vp-cons-pct { font-family: var(--vp-font-mono); font-weight: 700; font-size: 13px; color: var(--vp-text); }
        .vp-cons-label { font-family: var(--vp-font-sans); font-weight: 400; font-size: 12px; color: var(--vp-text-muted); }
        .vp-cons-track { width: 152px; height: 6px; border-radius: 999px; background: var(--vp-border); overflow: hidden; }
        .vp-cons-fill  { display: block; height: 6px; border-radius: 999px; background: var(--vp-vote-up); }

        /* ── IdeaListRow (Figma 74:87) ────────────────────────────────────── */
        /* .vp-row ist jetzt ein <div>-Container (Vote-Control außerhalb des Ankers
           für valides HTML). .vp-row-inner ist der <a>-Link für den Zeilen-Inhalt. */
        .vp-cards  { padding: 24px 0 64px; display: flex; flex-direction: column; gap: 12px; list-style: none; margin: 0; }
        .vp-row    { display: flex; align-items: center; gap: 20px; background: var(--vp-surface-frost); border: 1px solid var(--vp-border); border-radius: 16px; box-shadow: var(--vp-row-shadow); padding: 18px 24px 18px 20px; transition: transform .12s ease, box-shadow .12s ease; }
        .vp-row:hover { transform: translateY(-1px); box-shadow: 0 12px 30px -6px rgba(20,23,26,.12); }
        .vp-row-inner { flex: 1; min-width: 0; display: flex; align-items: center; gap: 20px; text-decoration: none; color: inherit; }
        .vp-row-content { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 6px; }
        .vp-row-title { margin: 0; font-family: var(--vp-font-head); font-weight: 600; font-size: 17px; line-height: 1.22; color: var(--vp-text); }
        .vp-row-excerpt { margin: 0; font-family: var(--vp-font-sans); font-weight: 400; font-size: 14px; line-height: 1.5; color: var(--vp-text-muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 100%; }
        .vp-row-meta  { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
        .vp-meta-txt { font-family: var(--vp-font-sans); font-weight: 400; font-size: 12px; color: var(--vp-text-faint); white-space: nowrap; }
        .vp-row-stats { flex-shrink: 0; width: 160px; display: flex; flex-direction: column; align-items: flex-start; }
        .vp-row-chev { flex-shrink: 0; font-size: 22px; line-height: 1; color: var(--vp-text-faint); }
        /* Anon-Login-Link-Arrows: kein Text-Underline, Farbe erben. */
        a.vp-vote-btn { text-decoration: none; color: inherit; }

        /* ── FeaturedIdeaCard (Figma 69:85) ───────────────────────────────── */
        /* .vp-feat-card ist jetzt ein <div>-Container, .vp-feat-inner der <a>-Link. */
        .vp-feat { display: flex; gap: 14px; align-items: stretch; }
        .vp-feat-card { flex: 1; min-width: 0; display: flex; gap: 22px; align-items: flex-start; background: var(--vp-surface); border: 1px solid var(--vp-border); border-radius: 20px; box-shadow: var(--vp-row-shadow); padding: 24px 26px 24px 24px; transition: transform .12s ease, box-shadow .12s ease; }
        .vp-feat-card:hover { transform: translateY(-1px); box-shadow: 0 12px 30px -6px rgba(20,23,26,.12); }
        .vp-feat-inner { flex: 1; min-width: 0; text-decoration: none; color: inherit; }
        .vp-feat-content { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 11px; }
        .vp-feat-eyebrow { margin: 0; font-family: var(--vp-font-sans); font-weight: 700; font-size: 11px; letter-spacing: 1.32px; color: var(--vp-vote-up); }
        .vp-feat-title { margin: 0; font-family: var(--vp-font-head); font-weight: 600; font-size: 25px; line-height: 1.16; letter-spacing: -.01em; color: var(--vp-text); }
        .vp-feat-desc { margin: 0; font-family: var(--vp-font-sans); font-weight: 400; font-size: 15px; line-height: 1.48; color: var(--vp-text-muted); }
        .vp-feat-meta { display: flex; align-items: center; gap: 18px; flex-wrap: wrap; padding-top: 2px; }
        .vp-bento { flex-shrink: 0; width: 300px; display: flex; flex-direction: column; gap: 16px; background: var(--vp-surface); border: 1px solid var(--vp-border); border-radius: 20px; box-shadow: var(--vp-row-shadow); padding: 22px; }
        .vp-bento-label { margin: 0; font-family: var(--vp-font-sans); font-weight: 700; font-size: 11px; letter-spacing: 1.1px; color: var(--vp-text-faint); }
        .vp-bento-stat { display: flex; flex-direction: column; gap: 2px; }
        .vp-bento-num { margin: 0; font-family: var(--vp-font-mono); font-weight: 700; font-size: 24px; line-height: 1; color: var(--vp-text); }
        .vp-bento-num--green { color: var(--vp-vote-up); }
        .vp-bento-cap { margin: 0; font-family: var(--vp-font-sans); font-weight: 400; font-size: 13px; color: var(--vp-text-muted); }

        /* ── Responsive (Web-Anwendung, nicht fixe Figma-Leinwand) ────────── */
        @media (max-width: 860px) {
            .vp-feat { flex-direction: column; }
            .vp-bento { width: 100%; }
        }
        @media (max-width: 680px) {
            .vp-row-stats { display: none; }
            .vp-row-chev  { display: none; }
            .vp-feat-card { padding: 20px; gap: 16px; }
            .vp-feat-meta { gap: 12px; }
            .vp-header-inner { padding-top: 12px; padding-bottom: 12px; }
            .vp-nav { gap: 14px; }
        }

        /* ── Detail/Form-Card + Hilfsklassen ──────────────────────────────── */
        .vp-mono { font-family: var(--vp-font-mono); }
        .vp-divider { border: none; border-top: 1px solid var(--vp-border); margin: 1.25rem 0; }

        {% block styles %}{% endblock %}
    </style>
    {% block head_extra %}{% endblock %}
</head>
<body>
    {# Marken-Backdrop (dekorativ, 1:1 zur Landing) — außerhalb aller überschreibbaren Blöcke. #}
    <div class="vp-backdrop" aria-hidden="true">
        <svg class="vp-hex vp-hex--tr" viewBox="-185 -205 370 410" width="540" height="599" fill="none">
            <g class="vp-hex-g">
                <path class="vp-h vp-h--top"  d="M 165.0 0.0 L 165.0 -44.0 Q 165.0 -72.0 141.6 -87.3 L 23.4 -164.7 Q 0.0 -180.0 -23.4 -164.7 L -141.6 -87.3 Q -165.0 -72.0 -165.0 -44.0 L -165.0 0.0 Z" fill="#0E9466" />
                <path class="vp-h vp-h--bot"  d="M -165.0 0.0 L -165.0 44.0 Q -165.0 72.0 -141.6 87.3 L -23.4 164.7 Q 0.0 180.0 23.4 164.7 L 141.6 87.3 Q 165.0 72.0 165.0 44.0 L 165.0 0.0 Z" fill="#D8503C" />
                <path class="vp-h vp-h--mid"  d="M -15.9 -112.0 Q 0.0 -122.4 15.9 -112.0 L 96.3 -59.4 Q 112.2 -49.0 112.2 -29.9 L 112.2 29.9 Q 112.2 49.0 96.3 59.4 L 15.9 112.0 Q 0.0 122.4 -15.9 112.0 L -96.3 59.4 Q -112.2 49.0 -112.2 29.9 L -112.2 -29.9 Q -112.2 -49.0 -96.3 -59.4 Z" fill="#084C37" />
                <path class="vp-h vp-h--dark" d="M -11.7 -82.3 Q 0.0 -90.0 11.7 -82.3 L 70.8 -43.7 Q 82.5 -36.0 82.5 -22.0 L 82.5 22.0 Q 82.5 36.0 70.8 43.7 L 11.7 82.3 Q 0.0 90.0 -11.7 82.3 L -70.8 43.7 Q -82.5 36.0 -82.5 22.0 L -82.5 -22.0 Q -82.5 -36.0 -70.8 -43.7 Z" fill="#05241A" />
            </g>
        </svg>
        <svg class="vp-hex vp-hex--bl" viewBox="-185 -205 370 410" width="380" height="421" fill="none">
            <g class="vp-hex-g">
                <path class="vp-h vp-h--top"  d="M 165.0 0.0 L 165.0 -44.0 Q 165.0 -72.0 141.6 -87.3 L 23.4 -164.7 Q 0.0 -180.0 -23.4 -164.7 L -141.6 -87.3 Q -165.0 -72.0 -165.0 -44.0 L -165.0 0.0 Z" fill="#0E9466" />
                <path class="vp-h vp-h--bot"  d="M -165.0 0.0 L -165.0 44.0 Q -165.0 72.0 -141.6 87.3 L -23.4 164.7 Q 0.0 180.0 23.4 164.7 L 141.6 87.3 Q 165.0 72.0 165.0 44.0 L 165.0 0.0 Z" fill="#D8503C" />
                <path class="vp-h vp-h--mid"  d="M -15.9 -112.0 Q 0.0 -122.4 15.9 -112.0 L 96.3 -59.4 Q 112.2 -49.0 112.2 -29.9 L 112.2 29.9 Q 112.2 49.0 96.3 59.4 L 15.9 112.0 Q 0.0 122.4 -15.9 112.0 L -96.3 59.4 Q -112.2 49.0 -112.2 29.9 L -112.2 -29.9 Q -112.2 -49.0 -96.3 -59.4 Z" fill="#084C37" />
                <path class="vp-h vp-h--dark" d="M -11.7 -82.3 Q 0.0 -90.0 11.7 -82.3 L 70.8 -43.7 Q 82.5 -36.0 82.5 -22.0 L 82.5 22.0 Q 82.5 36.0 70.8 43.7 L 11.7 82.3 Q 0.0 90.0 -11.7 82.3 L -70.8 43.7 Q -82.5 36.0 -82.5 22.0 L -82.5 -22.0 Q -82.5 -36.0 -70.8 -43.7 Z" fill="#05241A" />
            </g>
        </svg>
    </div>
    {% block body %}
    <main class="vp-wrap">
        {% block brand_logo %}
        {% if brand_logo_url|default('') is not empty %}
        <img class="vp-logo" src="{{ brand_logo_url }}" alt="">
        {% else %}
        <a class="vp-brand" href="/" aria-label="Votepit">
            <img class="vp-brand-icon" src="/assets/brand/votepit-icon.svg" alt="">
            <span class="vp-brand-word">Vote<span class="vp-brand-pit">pit</span></span>
        </a>
        {% endif %}
        {% endblock %}
        {% block content %}{% endblock %}
        {% block footer %}
        <footer class="vp-footer">Votepit</footer>
        {% endblock %}
    </main>
    {% endblock %}
    {# Persistente Votepit-Attribution — außerhalb aller überschreibbaren Blöcke,
       nicht via Board-Branding entfernbar. Fester Text/Link, kein |raw. #}
    <p class="vp-attr">Bereitgestellt mit <a href="https://votepit.com">Votepit</a></p>
</body>
</html>
