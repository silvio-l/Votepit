{#
  base.twig — Votepit Base-Layout (Issue 07, Sprint 2)

  ┌─ Marken-Tokens (pro Board in Issue 08 überschreibbar) ──────────────────┐
  │ --vp-primary            Brand-Primärfarbe (Ink/Schwarz Standard)         │
  │ --vp-secondary          Brand-Sekundär-/Akzentfarbe                      │
  │ --vp-primary-contrast   Text auf --vp-primary                            │
  │ --vp-primary-glow       Dezenter Glow um primäre Elemente                │
  │ --vp-bg                 Seitenhintergrund (warm-neutral)                  │
  │ --vp-surface            Frosted-Glass-Karten-Fläche                      │
  │ --vp-surface-border     Glasrand                                          │
  │ --vp-border             Subtile Trennlinie                                │
  │ --vp-radius             Squircle-Näherung (Karte)                         │
  │ --vp-radius-sm          Squircle-Näherung (kleine Elemente)               │
  │ --vp-text               Primärtext                                        │
  │ --vp-text-muted         Sekundärtext                                      │
  └────────────────────────────────────────────────────────────────────────────┘

  ┌─ Semantische Tokens (NICHT Board-überschreibbar) ──────────────────────┐
  │ --vp-vote-up / --vp-vote-up-bg      Up-Vote (Grün)                      │
  │ --vp-vote-down / --vp-vote-down-bg  Down-Vote (Vermillion)              │
  │ --vp-consensus-high                 Hoher Konsens (Grün)                │
  │ --vp-consensus-low                  Umstritten (Vermillion)             │
  │ --vp-status-open/planned/…          Idea-Status-Farben                  │
  │ --vp-font-sans/head/mono            Typografie-Stack                    │
  └────────────────────────────────────────────────────────────────────────────┘

  Issue 08 überschreibt ausschließlich die Marken-Tokens per Inline-Custom-
  Properties am <html>-Element. Semantische Tokens sind bewusst nicht
  überschreibbar — Up/Down/Konsens-Lesbarkeit ist brand-unabhängig.
#}
<!DOCTYPE html>
{#
  brand_style: vom Server (BrandingValidator::inlineStyle) erzeugter String aus
  ausschließlich validierten Marken-Token-Overrides (--vp-primary/--vp-secondary).
  Inline am <html> gewinnt per Kaskade gegen die :root-Defaults; ist er leer,
  greift das Default-Theme. Semantische Tokens werden hier NIE überschrieben.
#}
<html lang="de"{% if brand_style|default('') is not empty %} style="{{ brand_style }}"{% endif %}>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Votepit{% endblock %}</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <link rel="icon" href="/favicon-32.png" sizes="32x32" type="image/png">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <style>
        /* ── Self-hosted Webfonts (Light Modern: Archivo/Inter/JetBrains Mono) ── */
        @font-face { font-family: "Archivo"; font-style: normal; font-weight: 600; font-display: swap; src: url("/assets/fonts/archivo-600.woff2") format("woff2"); }
        @font-face { font-family: "Archivo"; font-style: normal; font-weight: 700; font-display: swap; src: url("/assets/fonts/archivo-700.woff2") format("woff2"); }
        @font-face { font-family: "Inter"; font-style: normal; font-weight: 400; font-display: swap; src: url("/assets/fonts/inter-400.woff2") format("woff2"); }
        @font-face { font-family: "Inter"; font-style: normal; font-weight: 500; font-display: swap; src: url("/assets/fonts/inter-500.woff2") format("woff2"); }
        @font-face { font-family: "Inter"; font-style: normal; font-weight: 600; font-display: swap; src: url("/assets/fonts/inter-600.woff2") format("woff2"); }
        @font-face { font-family: "JetBrains Mono"; font-style: normal; font-weight: 600; font-display: swap; src: url("/assets/fonts/jbmono-600.woff2") format("woff2"); }
        @font-face { font-family: "JetBrains Mono"; font-style: normal; font-weight: 700; font-display: swap; src: url("/assets/fonts/jbmono-700.woff2") format("woff2"); }

        /* ── Marken-Tokens (Board-überschreibbar via Issue 08) ──────────── */
        :root {
            --vp-primary:          #15161A;
            --vp-secondary:        #0E5C6E;
            --vp-primary-contrast: #ffffff;
            --vp-primary-glow:     rgba(21, 22, 26, 0.12);
            --vp-bg:               #F6F6F3;
            --vp-surface:          rgba(255, 255, 255, 0.72);
            --vp-surface-border:   rgba(255, 255, 255, 0.55);
            --vp-border:           rgba(21, 22, 26, 0.10);
            --vp-radius:           16px;
            --vp-radius-sm:        10px;
            --vp-text:             #15161A;
            --vp-text-muted:       #565A62;
            --vp-surface-subtle:   #f1f1ee;
            --vp-surface-hover:    rgba(21, 22, 26, .05);
            --vp-code-text:        #e9e9e7;
        }

        /* ── Semantische Tokens (NICHT Board-überschreibbar) ────────────── */
        :root {
            /* Voting — Grün (Up) / Vermillion (Down) */
            --vp-vote-up:            #0E9466;
            --vp-vote-up-bg:         #dcfce7;
            --vp-vote-down:          #D8503C;
            --vp-vote-down-bg:       #fee2e2;

            /* Konsens */
            --vp-consensus-high:     #0E9466;
            --vp-consensus-low:      #D8503C;

            /* Idea-Status */
            --vp-status-open:        #979BA3;
            --vp-status-planned:     #2E73D6;
            --vp-status-in-progress: #C0821A;
            --vp-status-done:        #0E9466;
            --vp-status-declined:    #D8503C;

            /* Typografie (Archivo Headlines + Inter Body + JetBrains Mono Zahlen) */
            --vp-font-sans: "Inter", ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            --vp-font-head: "Archivo", "Inter", ui-sans-serif, system-ui, sans-serif;
            --vp-font-mono: "JetBrains Mono", ui-monospace, "Cascadia Code", "Fira Code", monospace;
        }

        /* ── Reset ───────────────────────────────────────────────────────── */
        *, *::before, *::after { box-sizing: border-box; }

        body {
            margin: 0;
            font-family: var(--vp-font-sans);
            color: var(--vp-text);
            background: var(--vp-bg);
            line-height: 1.5;
            -webkit-font-smoothing: antialiased;
        }

        /* ── Karte (Frosted-Glass + Squircle-Näherung) ───────────────────── */
        .vp-card {
            background: var(--vp-surface);
            border: 1px solid var(--vp-surface-border);
            border-radius: var(--vp-radius);
            padding: 2rem 2.25rem;
            box-shadow:
                0 0 0 1px var(--vp-border),
                0 4px 24px var(--vp-primary-glow),
                0 1px 3px rgba(21, 22, 26, .06);
            backdrop-filter: blur(16px) saturate(1.2);
            -webkit-backdrop-filter: blur(16px) saturate(1.2);
        }

        /* ── Primär-Button ───────────────────────────────────────────────── */
        .vp-btn {
            display: inline-block;
            width: 100%;
            margin-top: 1rem;
            padding: .65rem 1rem;
            background: var(--vp-primary);
            color: var(--vp-primary-contrast);
            border: none;
            border-radius: var(--vp-radius-sm);
            font-family: var(--vp-font-sans);
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: opacity .15s;
            text-align: center;
        }
        .vp-btn:hover { opacity: .85; }

        /* ── Eingabefeld ─────────────────────────────────────────────────── */
        .vp-input {
            width: 100%;
            padding: .6rem .8rem;
            border: 1px solid var(--vp-border);
            border-radius: var(--vp-radius-sm);
            font-family: var(--vp-font-sans);
            font-size: 1rem;
            color: var(--vp-text);
            background: var(--vp-surface);
            outline: none;
            transition: border-color .15s;
        }
        .vp-input:focus { border-color: var(--vp-primary); }

        /* ── Typografie-Helfer ───────────────────────────────────────────── */
        .vp-wrap   { max-width: 460px; margin: 12vh auto; padding: 2.5rem 1.5rem; }
        .vp-h1     { margin: 0 0 .25rem; font-family: var(--vp-font-head); font-size: 1.5rem; letter-spacing: -.02em; }
        .vp-lead   { color: var(--vp-text-muted); margin: .5rem 0 1.5rem; font-size: .95rem; }
        .vp-label  { display: block; font-size: .875rem; font-weight: 500; margin-bottom: .4rem; }
        .vp-footer { margin-top: 1.5rem; color: var(--vp-text-muted); font-size: .8rem; text-align: center; }
        .vp-link   { color: var(--vp-primary); }
        .vp-icon   { font-size: 2rem; margin-bottom: .75rem; display: block; }

        /* Votepit-Wortbildmarke (Default-Markenzeichen, wenn kein Board-Logo) */
        .vp-brand      { display: inline-flex; align-items: center; gap: .04em; margin-bottom: 1.25rem;
                         text-decoration: none; font-family: var(--vp-font-head); font-weight: 800;
                         letter-spacing: -.02em; font-size: 1.6rem; line-height: 1; }
        .vp-brand-icon { height: 1.5em; width: auto; display: block; margin-right: .02em; }
        .vp-brand-word { color: var(--vp-text); }
        .vp-brand-pit  { color: var(--vp-vote-down); }
        .vp-logo       { max-height: 2.5rem; width: auto; display: block; margin-bottom: 1.25rem; }

        /* ── Persistente Attribution (nicht board-überschreibbar) ────────── */
        .vp-attr { margin: 1rem 0 0; color: var(--vp-text-muted); font-size: .75rem; text-align: center; opacity: .7; }
        .vp-attr a { color: inherit; text-decoration: underline; text-underline-offset: 2px; }

        /* ════════════════════════════════════════════════════════════════════
           Geteilte App-Komponenten (Board/Detail/Formulare/Admin) — Light Modern
           ════════════════════════════════════════════════════════════════════ */

        /* Weicher Grün-Glow oben (Tiefe durch Licht, nicht durch Kanten) */
        body::before {
            content: "";
            position: fixed;
            inset: 0 0 auto 0;
            height: 420px;
            background:
                radial-gradient(60% 100% at 22% -10%, rgba(14,148,102,.10), transparent 70%),
                radial-gradient(50% 100% at 90% -20%, rgba(192,130,26,.06), transparent 70%);
            pointer-events: none;
            z-index: 0;
        }

        /* Zentrierter App-Shell (breiter als die schmale Auth-Spalte) */
        .vp-shell { position: relative; z-index: 1; max-width: 820px; margin: 0 auto; padding: 1.25rem 1.5rem 4rem; }

        /* ── Topbar (Logo links, Aktionen rechts) ─────────────────────────── */
        .vp-topbar { display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: .25rem 0 1.75rem; }
        .vp-topbar-brand { display: inline-flex; align-items: center; gap: .04em; text-decoration: none; font-family: var(--vp-font-head); font-weight: 700; letter-spacing: -.02em; font-size: 1.3rem; line-height: 1; }
        .vp-topbar-brand img { height: 1.45em; width: auto; display: block; }
        .vp-topbar-brand .w { color: var(--vp-text); }
        .vp-topbar-brand .p { color: var(--vp-vote-down); }
        .vp-topbar-ctx { display: inline-flex; align-items: center; gap: .55rem; font-family: var(--vp-font-head); font-weight: 700; font-size: 1.05rem; letter-spacing: -.01em; color: var(--vp-text); text-decoration: none; }
        .vp-topbar-avatar { width: 1.85rem; height: 1.85rem; border-radius: 9px; background: var(--vp-primary); color: var(--vp-primary-contrast); display: inline-flex; align-items: center; justify-content: center; font-family: var(--vp-font-head); font-weight: 700; font-size: .9rem; }
        .vp-topbar-actions { display: inline-flex; align-items: center; gap: .85rem; }

        /* Pill-Buttons (klein, für Topbar/Inline) */
        .vp-pill { display: inline-flex; align-items: center; gap: .35rem; padding: .5rem 1rem; border-radius: 999px; font-size: .85rem; font-weight: 600; text-decoration: none; cursor: pointer; border: 1px solid transparent; transition: opacity .15s, border-color .15s, background .15s; }
        .vp-pill--primary { background: var(--vp-primary); color: var(--vp-primary-contrast); }
        .vp-pill--primary:hover { opacity: .88; }
        .vp-pill--ghost { background: transparent; color: var(--vp-text-muted); }
        .vp-pill--ghost:hover { color: var(--vp-text); }
        .vp-pill--outline { background: var(--vp-surface); color: var(--vp-text); border-color: var(--vp-border); }
        .vp-pill--outline:hover { border-color: var(--vp-text); }

        /* ── Hero (Board-Kopf) ────────────────────────────────────────────── */
        .vp-hero { margin: .25rem 0 1.75rem; }
        .vp-hero-title { margin: 0; font-family: var(--vp-font-head); font-weight: 700; font-size: 2rem; line-height: 1.12; letter-spacing: -.025em; color: var(--vp-text); }
        .vp-hero-sub { margin: .6rem 0 0; color: var(--vp-text-muted); font-size: 1rem; max-width: 46ch; }

        /* ── Vote-Control (Optik der Signatur; Interaktion ab Sprint 4) ────── */
        .vp-votebox { flex-shrink: 0; display: inline-flex; flex-direction: column; align-items: center; gap: .15rem; padding: .4rem .55rem; border-radius: 14px; border: 1px solid var(--vp-border); background: var(--vp-surface-subtle); min-width: 3.1rem; }
        .vp-votebox-btn { display: flex; align-items: center; justify-content: center; width: 1.5rem; height: 1.1rem; color: var(--vp-text-muted); opacity: .5; }
        .vp-votebox-btn svg { width: 14px; height: 14px; display: block; }
        .vp-votebox-score { font-family: var(--vp-font-mono); font-weight: 700; font-size: 1.15rem; line-height: 1.1; color: var(--vp-text); }
        .vp-votebox-score--neg { color: var(--vp-vote-down); }
        .vp-votebox--lg { min-width: 4.2rem; padding: .65rem .8rem; gap: .25rem; }
        .vp-votebox--lg .vp-votebox-btn { width: 2rem; height: 1.4rem; }
        .vp-votebox--lg .vp-votebox-btn svg { width: 18px; height: 18px; }
        .vp-votebox--lg .vp-votebox-score { font-size: 1.9rem; }

        /* ── Status-Badge ─────────────────────────────────────────────────── */
        .vp-status-badge { display: inline-flex; align-items: center; gap: .3rem; padding: .15rem .55rem; border-radius: 999px; font-size: .7rem; font-weight: 600; text-transform: uppercase; letter-spacing: .04em; }
        .vp-status-badge::before { content: ""; width: .42rem; height: .42rem; border-radius: 50%; background: currentColor; }
        .vp-status-open        { background: rgba(151,155,163,.14); color: var(--vp-status-open); }
        .vp-status-planned     { background: rgba(46,115,214,.12);  color: var(--vp-status-planned); }
        .vp-status-in_progress { background: rgba(192,130,26,.12);  color: var(--vp-status-in-progress); }
        .vp-status-done        { background: rgba(14,148,102,.12);  color: var(--vp-status-done); }
        .vp-status-declined    { background: rgba(216,80,60,.12);   color: var(--vp-status-declined); }

        /* ── Mono-Helfer / Divider ────────────────────────────────────────── */
        .vp-mono { font-family: var(--vp-font-mono); }
        .vp-divider { border: none; border-top: 1px solid var(--vp-border); margin: 1.25rem 0; }

        {% block styles %}{% endblock %}
    </style>
    {% block head_extra %}{% endblock %}
</head>
<body>
    {% block body %}
    <main class="vp-wrap">
        {% block brand_logo %}
        {% if brand_logo_url|default('') is not empty %}
        <img class="vp-logo" src="{{ brand_logo_url }}" alt="">
        {% else %}
        <a class="vp-brand" href="/" aria-label="Votepit">
            <img class="vp-brand-icon" src="/assets/brand/votepit-icon.svg" alt="">
            <span class="vp-brand-word">Vote<span class="vp-brand-pit">pit</span></span>
        </a>
        {% endif %}
        {% endblock %}
        {% block content %}{% endblock %}
        {% block footer %}
        <footer class="vp-footer">Votepit</footer>
        {% endblock %}
    </main>
    {% endblock %}
    {# Persistente Votepit-Attribution — außerhalb aller überschreibbaren Blöcke,
       nicht via Board-Branding entfernbar. Fester Text/Link, kein |raw. #}
    <p class="vp-attr">Bereitgestellt mit <a href="https://votepit.com">Votepit</a></p>
</body>
</html>
