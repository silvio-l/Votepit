{% extends 'base.twig' %}

{% block title %}Idee bearbeiten · {{ board_name }} · Votepit{% endblock %}

{% block styles %}
.vp-back { display: inline-flex; align-items: center; gap: .35rem; font-family: var(--vp-font-sans); font-weight: 500; font-size: 14px; color: var(--vp-text-muted); text-decoration: none; margin: 24px 0 18px; transition: color .12s; }
.vp-back:hover { color: var(--vp-text); }
.vp-form-card { max-width: 680px; background: var(--vp-surface); border: 1px solid var(--vp-border); border-radius: 20px; box-shadow: var(--vp-row-shadow); padding: 28px 30px; backdrop-filter: blur(16px) saturate(1.2); -webkit-backdrop-filter: blur(16px) saturate(1.2); }
.vp-form-title { margin: 0 0 .3rem; font-family: var(--vp-font-head); font-weight: 700; font-size: 24px; letter-spacing: -.02em; color: var(--vp-text); }
.vp-form-lead { margin: 0 0 1.75rem; color: var(--vp-text-muted); font-size: 14px; }
.vp-field { margin-bottom: 1.25rem; }
.vp-field-error { margin: .35rem 0 0; color: var(--vp-vote-down); font-size: .825rem; }
.vp-input--error, .vp-textarea--error { border-color: var(--vp-vote-down); }
.vp-textarea { width: 100%; padding: .6rem .8rem; border: 1px solid var(--vp-border); border-radius: var(--vp-radius-sm); font-family: var(--vp-font-sans); font-size: 1rem; color: var(--vp-text); background: var(--vp-surface); outline: none; transition: border-color .15s; resize: vertical; min-height: 8rem; line-height: 1.5; }
.vp-textarea:focus, .vp-input:focus { border-color: var(--vp-accent); }
.vp-foot { padding: 32px 0 48px; color: var(--vp-text-faint); font-size: 13px; }
.vp-foot a { color: var(--vp-text-muted); }
{% endblock %}

{% block body %}
<div class="vp-shell">
    <header class="vp-header">
        <div class="vp-header-inner">
            <a class="vp-logo-ctx" href="/{{ board_slug }}">
                <span class="vp-logo-avatar">{{ board_name|slice(0,1)|upper }}</span>
                <span class="vp-logo-ctx-name">{{ board_name }}</span>
            </a>
        </div>
    </header>

    <main class="vp-container">
        <a class="vp-back" href="/{{ board_slug }}/ideas/{{ idea.id }}">← Zurück zur Idee</a>

        <div class="vp-form-card">
            <h1 class="vp-form-title">Idee bearbeiten</h1>
            <p class="vp-form-lead">Passe Titel und Beschreibung an. Reiner Text, kein Markdown.</p>

            <form method="post" action="/{{ board_slug }}/ideas/{{ idea.id }}" novalidate>
                <input type="hidden" name="_csrf" value="{{ csrf_token }}">
                <input type="hidden" name="_form_at" value="{{ time_trap }}">
                {# Honeypot — muss leer bleiben; versteckt für Menschen und Screenreader #}
                <div aria-hidden="true" style="display:none;">
                    <label for="hp-website">Website</label>
                    <input id="hp-website" type="text" name="website" value="" tabindex="-1" autocomplete="off">
                </div>

                {% if errors.moderation is defined %}
                <div role="alert" style="margin-bottom:1.25rem;padding:.7rem 1rem;border-radius:var(--vp-radius-sm);background:color-mix(in srgb,var(--vp-vote-down) 8%,transparent);border:1px solid color-mix(in srgb,var(--vp-vote-down) 30%,transparent);color:var(--vp-vote-down);font-size:.875rem;">
                    {% for msg in errors.moderation %}{{ msg }}{% endfor %}
                </div>
                {% endif %}

                <div class="vp-field">
                    <label class="vp-label" for="idea-title">Titel <span aria-hidden="true" style="color:var(--vp-vote-down)">*</span></label>
                    <input id="idea-title" class="vp-input{% if errors.title is defined %} vp-input--error{% endif %}" type="text" name="title" value="{{ values.title }}" maxlength="200" required autocomplete="off" aria-required="true" {% if errors.title is defined %}aria-describedby="title-error"{% endif %}>
                    {% if errors.title is defined %}
                    <ul id="title-error" class="vp-field-error" role="alert" style="list-style:none;margin:.35rem 0 0;padding:0;">
                        {% for msg in errors.title %}<li>{{ msg }}</li>{% endfor %}
                    </ul>
                    {% endif %}
                </div>

                <div class="vp-field">
                    <label class="vp-label" for="idea-body">Beschreibung <span aria-hidden="true" style="color:var(--vp-vote-down)">*</span></label>
                    <textarea id="idea-body" class="vp-textarea{% if errors.body is defined %} vp-textarea--error{% endif %}" name="body" required aria-required="true" {% if errors.body is defined %}aria-describedby="body-error"{% endif %}>{{ values.body }}</textarea>
                    {% if errors.body is defined %}
                    <ul id="body-error" class="vp-field-error" role="alert" style="list-style:none;margin:.35rem 0 0;padding:0;">
                        {% for msg in errors.body %}<li>{{ msg }}</li>{% endfor %}
                    </ul>
                    {% endif %}
                </div>

                <button type="submit" class="vp-btn2 vp-btn2--primary">Änderungen speichern</button>
            </form>
        </div>
    </main>
</div>
{% endblock %}
