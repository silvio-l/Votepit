{% extends 'base.twig' %}
{% import 'components/ui.twig' as ui %}

{% block title %}{{ board_name }} · Votepit{% endblock %}

{% block styles %}
.vp-empty { text-align: center; padding: 4rem 1rem; color: var(--vp-text-muted); background: var(--vp-surface-frost); border: 1px solid var(--vp-border); border-radius: 16px; box-shadow: var(--vp-row-shadow); }
.vp-empty-icon { font-size: 2.5rem; margin-bottom: .75rem; display: block; }
.vp-empty-title { font-family: var(--vp-font-head); font-weight: 700; font-size: 1.15rem; color: var(--vp-text); margin: 0 0 .5rem; }
.vp-empty-text { font-size: .92rem; margin: 0; }
.vp-pagination { display: flex; justify-content: center; align-items: center; gap: .75rem; padding: 0 0 48px; }
.vp-page-info { font-size: 13px; color: var(--vp-text-muted); font-family: var(--vp-font-mono); }
.vp-foot { padding: 8px 0 48px; color: var(--vp-text-faint); font-size: 13px; }
.vp-foot a { color: var(--vp-text-muted); }
{% endblock %}

{% block body %}
<div class="vp-shell">

    {# Header — full-bleed, sticky (Figma 66:32) #}
    <header class="vp-header">
        <div class="vp-header-inner">
            <a class="vp-logo" href="/" aria-label="Votepit">
                <img src="/assets/brand/votepit-icon.svg" alt="">
                <span class="vp-logo-word">Vote<span class="p">pit</span></span>
            </a>
            <nav class="vp-nav">
                <a class="vp-nav-link" href="/{{ board_slug }}">Roadmap</a>
                {% if is_authenticated %}
                <a class="vp-btn2 vp-btn2--primary vp-btn2--sm" href="/{{ board_slug }}/ideas/new">Neue Idee</a>
                {% else %}
                <a class="vp-btn2 vp-btn2--primary vp-btn2--sm" href="/login?r=/{{ board_slug }}">Anmelden</a>
                {% endif %}
            </nav>
        </div>
    </header>

    <main class="vp-container">

        {# Hero (Figma 81:57) #}
        <section class="vp-hero">
            <h1 class="vp-hero-title">{{ board_name }}</h1>
            {% if board_intro %}<p class="vp-hero-sub">{{ board_intro }}</p>{% endif %}
            <a class="vp-btn2 vp-btn2--primary" href="{{ is_authenticated ? '/' ~ board_slug ~ '/ideas/new' : '/login?r=/' ~ board_slug ~ '/ideas/new' }}">＋ Neue Idee</a>
        </section>

        {# Filter-Chips + SortTabs (Figma 81:63) #}
        <div class="vp-filter">
            {{ ui.filter_chips(board_slug, active_status, active_sort) }}
            {{ ui.sort_tabs(board_slug, active_sort, active_status, page) }}
        </div>

        {# Cards (Figma 81:84) #}
        {% if ideas|length == 0 %}
        <div class="vp-cards">
            <div class="vp-empty">
                <span class="vp-empty-icon">💡</span>
                <p class="vp-empty-title">Noch keine Ideen</p>
                <p class="vp-empty-text">
                    {% if active_status is not null %}
                        Keine Ideen mit diesem Status. <a class="vp-link" href="/{{ board_slug }}">Alle anzeigen</a>
                    {% else %}
                        Sei der Erste und reiche eine Idee ein!
                    {% endif %}
                </p>
            </div>
        </div>
        {% else %}
        {% set show_featured = active_status is null and page == 1 %}
        {% if show_featured %}
            {% set featured = ideas|sort((a, b) => b.score_cache <=> a.score_cache)|first %}
            {% set rows = ideas|filter(i => i.id != featured.id) %}
            {% set v_total = ideas|reduce((c, i) => c + i.up_count + i.down_count, 0) %}
            {% set cons_list = ideas|filter(i => (i.up_count + i.down_count) > 0)|map(i => i.up_count / (i.up_count + i.down_count) * 100) %}
            {% set cons_avg = cons_list|length > 0 ? (cons_list|reduce((c, x) => c + x, 0) / cons_list|length)|round : 0 %}
            {% set stats = {'votes_total': v_total, 'ideas_total': total_ideas|default(ideas|length), 'consensus_avg': cons_avg} %}
        {% else %}
            {% set rows = ideas %}
        {% endif %}
        <div class="vp-cards">
            {% if show_featured %}{{ ui.featured_card(featured, board_slug, stats, csrf_token, is_authenticated) }}{% endif %}
            {% for idea in rows %}{{ ui.idea_row(idea, board_slug, csrf_token, is_authenticated) }}{% endfor %}
        </div>
        {% endif %}

        {% if total_pages|default(1) > 1 %}
        {% set _sort_qs = active_sort is defined and active_sort != 'newest' ? '&amp;sort=' ~ active_sort : '' %}
        <nav class="vp-pagination" aria-label="Seitennavigation">
            {% if page > 1 %}
            <a class="vp-btn2 vp-btn2--secondary vp-btn2--sm" href="/{{ board_slug }}?page={{ page - 1 }}{{ _sort_qs }}{% if active_status is not null %}&amp;status={{ active_status }}{% endif %}">← Zurück</a>
            {% endif %}
            <span class="vp-page-info">{{ page }} / {{ total_pages }}</span>
            {% if page < total_pages %}
            <a class="vp-btn2 vp-btn2--secondary vp-btn2--sm" href="/{{ board_slug }}?page={{ page + 1 }}{{ _sort_qs }}{% if active_status is not null %}&amp;status={{ active_status }}{% endif %}">Weiter →</a>
            {% endif %}
        </nav>
        {% endif %}
    </main>
</div>
{% endblock %}
