{% extends 'base.twig' %}

{% block title %}{{ board_name }} · Votepit{% endblock %}

{% block styles %}
/* ── Board-Home Layout ─────────────────────────────────────────────── */
.vp-wrap--board { max-width: 720px; }

.vp-board-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.5rem;
}

.vp-board-title {
    margin: 0;
    font-family: var(--vp-font-head);
    font-size: 1.75rem;
    letter-spacing: -.02em;
    font-weight: 800;
    color: var(--vp-text);
}

.vp-board-intro {
    margin: .4rem 0 0;
    color: var(--vp-text-muted);
    font-size: .925rem;
}

/* ── Filter-Bar ────────────────────────────────────────────────────── */
.vp-filter-bar {
    display: flex;
    align-items: center;
    gap: .5rem;
    margin-bottom: 1.25rem;
    flex-wrap: wrap;
}

.vp-filter-link {
    padding: .3rem .75rem;
    border-radius: 999px;
    font-size: .825rem;
    font-weight: 500;
    text-decoration: none;
    color: var(--vp-text-muted);
    border: 1px solid var(--vp-border);
    background: var(--vp-surface);
    transition: border-color .12s, color .12s;
}

.vp-filter-link:hover { color: var(--vp-text); border-color: var(--vp-text); }
.vp-filter-link--active { color: var(--vp-text); border-color: var(--vp-text); font-weight: 600; }

/* ── Idea-Liste ────────────────────────────────────────────────────── */
.vp-idea-list { display: flex; flex-direction: column; gap: .75rem; }

.vp-idea-card {
    background: var(--vp-surface);
    border: 1px solid var(--vp-surface-border);
    border-radius: var(--vp-radius);
    padding: 1.1rem 1.25rem;
    box-shadow:
        0 0 0 1px var(--vp-border),
        0 2px 12px var(--vp-primary-glow),
        0 1px 2px rgba(21, 22, 26, .04);
    backdrop-filter: blur(12px) saturate(1.15);
    -webkit-backdrop-filter: blur(12px) saturate(1.15);
    display: flex;
    align-items: flex-start;
    gap: 1rem;
}

.vp-idea-score {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: .2rem;
    min-width: 2.5rem;
    padding-top: .1rem;
}

.vp-idea-score-num {
    font-family: var(--vp-font-mono);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--vp-text);
    line-height: 1;
}

.vp-idea-score-label {
    font-size: .65rem;
    color: var(--vp-text-muted);
    text-transform: uppercase;
    letter-spacing: .05em;
}

.vp-idea-body { flex: 1; min-width: 0; }

.vp-idea-title {
    margin: 0 0 .3rem;
    font-size: 1rem;
    font-weight: 600;
    color: var(--vp-text);
    font-family: var(--vp-font-sans);
    line-height: 1.3;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.vp-idea-meta {
    font-size: .8rem;
    color: var(--vp-text-muted);
    display: flex;
    align-items: center;
    gap: .6rem;
    flex-wrap: wrap;
}

.vp-status-badge {
    padding: .15rem .5rem;
    border-radius: 999px;
    font-size: .7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .04em;
}

.vp-status-open        { background: rgba(151,155,163,.12); color: var(--vp-status-open); }
.vp-status-planned     { background: rgba(46,115,214,.1);   color: var(--vp-status-planned); }
.vp-status-in_progress { background: rgba(192,130,26,.1);   color: var(--vp-status-in-progress); }
.vp-status-done        { background: rgba(14,148,102,.1);   color: var(--vp-status-done); }
.vp-status-declined    { background: rgba(216,80,60,.1);    color: var(--vp-status-declined); }

/* ── Empty-State ───────────────────────────────────────────────────── */
.vp-empty {
    text-align: center;
    padding: 3rem 1rem;
    color: var(--vp-text-muted);
}

.vp-empty-icon { font-size: 2.5rem; margin-bottom: .75rem; display: block; }
.vp-empty-title { font-family: var(--vp-font-head); font-size: 1.1rem; color: var(--vp-text); margin: 0 0 .5rem; }
.vp-empty-text { font-size: .9rem; margin: 0; }

/* ── Pagination ────────────────────────────────────────────────────── */
.vp-pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: .75rem;
    margin-top: 1.5rem;
}

.vp-page-link {
    padding: .4rem .85rem;
    border-radius: var(--vp-radius-sm);
    border: 1px solid var(--vp-border);
    background: var(--vp-surface);
    color: var(--vp-text);
    text-decoration: none;
    font-size: .875rem;
    font-weight: 500;
    transition: border-color .12s;
}

.vp-page-link:hover { border-color: var(--vp-text); }
.vp-page-info { font-size: .8rem; color: var(--vp-text-muted); font-family: var(--vp-font-mono); }
{% endblock %}

{% block body %}
<main class="vp-wrap vp-wrap--board">

    {# Board-Header #}
    <div class="vp-board-header">
        <div>
            <h1 class="vp-board-title">{{ board_name }}</h1>
            {% if board_intro %}
            <p class="vp-board-intro">{{ board_intro }}</p>
            {% endif %}
        </div>
        {% if is_authenticated %}
        <a href="/{{ board_slug }}/ideas/new" class="vp-btn" style="width:auto;padding:.5rem 1.25rem;margin-top:0;text-decoration:none;">
            + Neue Idee
        </a>
        {% else %}
        <a href="/login?r=/{{ board_slug }}/ideas/new" class="vp-btn" style="width:auto;padding:.5rem 1.25rem;margin-top:0;text-decoration:none;background:var(--vp-surface);color:var(--vp-text);border:1px solid var(--vp-border);">
            Anmelden um eine Idee einzureichen
        </a>
        {% endif %}
    </div>

    {# Status-Filter-Bar #}
    <nav class="vp-filter-bar" aria-label="Status-Filter">
        <a href="/{{ board_slug }}{% if page > 1 %}?page={{ page }}{% endif %}"
           class="vp-filter-link{% if active_status is null %} vp-filter-link--active{% endif %}">
            Alle
        </a>
        {% for s in ['open', 'planned', 'in_progress', 'done', 'declined'] %}
        {% set labels = {
            'open':        'Offen',
            'planned':     'Geplant',
            'in_progress': 'In Arbeit',
            'done':        'Erledigt',
            'declined':    'Abgelehnt'
        } %}
        <a href="/{{ board_slug }}?status={{ s }}"
           class="vp-filter-link{% if active_status == s %} vp-filter-link--active{% endif %}">
            {{ labels[s] }}
        </a>
        {% endfor %}
    </nav>

    {# Ideenliste #}
    {% if ideas|length == 0 %}
    <div class="vp-card vp-empty">
        <span class="vp-empty-icon">💡</span>
        <p class="vp-empty-title">Noch keine Ideen</p>
        <p class="vp-empty-text">
            {% if active_status is not null %}
                Keine Ideen mit diesem Status. <a class="vp-link" href="/{{ board_slug }}">Alle anzeigen</a>
            {% else %}
                Sei der Erste und reiche eine Idee ein!
            {% endif %}
        </p>
    </div>
    {% else %}
    <ul class="vp-idea-list" style="list-style:none;margin:0;padding:0;">
        {% for idea in ideas %}
        <li>
            <article class="vp-idea-card">
                <div class="vp-idea-score" aria-label="Score {{ idea.score_cache }}">
                    <span class="vp-idea-score-num">{{ idea.score_cache }}</span>
                    <span class="vp-idea-score-label">Score</span>
                </div>
                <div class="vp-idea-body">
                    <h2 class="vp-idea-title">{{ idea.title }}</h2>
                    <div class="vp-idea-meta">
                        <span class="vp-status-badge vp-status-{{ idea.status }}">
                            {{ {
                                'open':        'Offen',
                                'planned':     'Geplant',
                                'in_progress': 'In Arbeit',
                                'done':        'Erledigt',
                                'declined':    'Abgelehnt'
                            }[idea.status] ?? idea.status }}
                        </span>
                        <span>{{ idea.created_at|date('d.m.Y') }}</span>
                    </div>
                </div>
            </article>
        </li>
        {% endfor %}
    </ul>

    {# Pagination #}
    {% if total_pages > 1 %}
    <nav class="vp-pagination" aria-label="Seitennavigation">
        {% if page > 1 %}
        <a class="vp-page-link"
           href="/{{ board_slug }}?page={{ page - 1 }}{% if active_status is not null %}&amp;status={{ active_status }}{% endif %}">
            ← Zurück
        </a>
        {% endif %}
        <span class="vp-page-info">{{ page }} / {{ total_pages }}</span>
        {% if page < total_pages %}
        <a class="vp-page-link"
           href="/{{ board_slug }}?page={{ page + 1 }}{% if active_status is not null %}&amp;status={{ active_status }}{% endif %}">
            Weiter →
        </a>
        {% endif %}
    </nav>
    {% endif %}
    {% endif %}

    {% block footer %}
    <footer class="vp-footer" style="margin-top:2rem;">
        {{ board_name }} · <a class="vp-link" href="/">Votepit</a>
    </footer>
    {% endblock %}
</main>
{% endblock %}
