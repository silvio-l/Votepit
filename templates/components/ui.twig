{#
  Votepit UI-Komponenten — 1:1 zu Figma Variante F, Referenz-Screen 80:33
  (File LF4w4ib8q7m8EAemr0P4k6). Wiederverwendbare Macros; CSS in base.twig.
  Import:  {% import 'components/ui.twig' as ui %}

  Status-Werte (DB): open · planned · in_progress · done · declined
#}

{% set _status_labels = {'open':'Offen','planned':'Geplant','in_progress':'In Arbeit','done':'Erledigt','declined':'Abgelehnt'} %}

{# Vote-Control (Figma VoteWidget 71:69). tone: '' neutral (heller Up) | 'up' leading (grüner Up).
   size: '' (Liste) | 'lg' (Detail). Anzeige-only — Interaktion folgt Sprint 4. #}
{% macro vote(score, tone = '', size = '') %}
<div class="vp-vote{{ size == 'lg' ? ' vp-vote--lg' : '' }}{{ tone == 'up' ? ' vp-vote--up' : '' }}" aria-label="Score {{ score }}">
    <span class="vp-vote-btn vp-vote-up" aria-hidden="true"><svg viewBox="0 0 12 8" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1.5 6 6 1.5 10.5 6"/></svg></span>
    <span class="vp-vote-score{{ score < 0 ? ' vp-vote-score--neg' : '' }}">{{ score }}</span>
    <span class="vp-vote-btn vp-vote-down" aria-hidden="true"><svg viewBox="0 0 12 8" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1.5 2 6 6.5 10.5 2"/></svg></span>
</div>
{% endmacro %}

{# Interaktives Vote-Control für eingeloggte User (Sprint 4, Issue 01/02).
   Zwei Mini-Formulare (Hoch/Runter), die OHNE JavaScript funktionieren (Form-POST → PRG).
   my_vote ∈ {'up','down','none'}: steuert den aktiven/gedrückten Zustand via
   token-gebundene CSS-Klassen vp-vote--up / vp-vote--down. Keine Hex-/Magic-Werte.
   size: '' (Liste) | 'lg' (Detail). #}
{% macro vote_form(score, board_slug, idea_id, csrf_token, size = '', my_vote = 'none') %}
<div class="vp-vote{{ size == 'lg' ? ' vp-vote--lg' : '' }}{{ my_vote == 'up' ? ' vp-vote--up' : (my_vote == 'down' ? ' vp-vote--down' : '') }}" aria-label="Score {{ score }}">
    <form class="vp-vote-form" method="post" action="/{{ board_slug }}/ideas/{{ idea_id }}/vote">
        <input type="hidden" name="_csrf" value="{{ csrf_token }}">
        <input type="hidden" name="value" value="up">
        <button type="submit" class="vp-vote-btn vp-vote-up" aria-label="Hochstimmen"><svg viewBox="0 0 12 8" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1.5 6 6 1.5 10.5 6"/></svg></button>
    </form>
    <span class="vp-vote-score{{ score < 0 ? ' vp-vote-score--neg' : '' }}">{{ score }}</span>
    <form class="vp-vote-form" method="post" action="/{{ board_slug }}/ideas/{{ idea_id }}/vote">
        <input type="hidden" name="_csrf" value="{{ csrf_token }}">
        <input type="hidden" name="value" value="down">
        <button type="submit" class="vp-vote-btn vp-vote-down" aria-label="Runterstimmen"><svg viewBox="0 0 12 8" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1.5 2 6 6.5 10.5 2"/></svg></button>
    </form>
</div>
{% endmacro %}

{# Anon-Vote-Control (Sprint 4, Issue 02): für nicht eingeloggte Besucher.
   Zeigt Score + Pfeil-Links statt Forms. Klick auf Pfeil → Login mit Return-To
   auf die Idee (Open-Redirect-sicher via url_encode = rawurlencode in Twig 3).
   size: '' (Liste) | 'lg' (Detail). #}
{% macro vote_anon(score, board_slug, idea_id, size = '') %}
{% set _r = ('/' ~ board_slug ~ '/ideas/' ~ idea_id)|url_encode %}
<div class="vp-vote{{ size == 'lg' ? ' vp-vote--lg' : '' }}" aria-label="Score {{ score }}">
    <a class="vp-vote-btn vp-vote-up" href="/login?r={{ _r }}" aria-label="Anmelden zum Hochstimmen"><svg viewBox="0 0 12 8" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1.5 6 6 1.5 10.5 6"/></svg></a>
    <span class="vp-vote-score{{ score < 0 ? ' vp-vote-score--neg' : '' }}">{{ score }}</span>
    <a class="vp-vote-btn vp-vote-down" href="/login?r={{ _r }}" aria-label="Anmelden zum Runterstimmen"><svg viewBox="0 0 12 8" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1.5 2 6 6.5 10.5 2"/></svg></a>
</div>
{% endmacro %}

{# Status-Badge Pill (Figma StatusBadge 61:47) — Frost-Pill, farbiger 6px-Punkt, Label Inter 12px secondary. #}
{% macro status_badge(s) %}
{% set labels = {'open':'Offen','planned':'Geplant','in_progress':'In Arbeit','done':'Erledigt','declined':'Abgelehnt'} %}
<span class="vp-badge vp-badge-{{ s }}"><span class="vp-badge-dot"></span><span class="vp-badge-label">{{ labels[s] ?? s }}</span></span>
{% endmacro %}

{# ConsensusBar (Figma 63:32) — Prozent (mono, primary) + „Konsens" + 152px-Track mit grünem Fill. #}
{% macro consensus_bar(pct) %}
<div class="vp-cons">
    <div class="vp-cons-head"><span class="vp-cons-pct">{{ pct }}%</span><span class="vp-cons-label">Konsens</span></div>
    <div class="vp-cons-track"><span class="vp-cons-fill" style="width: {{ pct }}%;"></span></div>
</div>
{% endmacro %}

{# Relative Zeitangabe „vor N Tagen" aus DATETIME-String. #}
{% macro ago(datetime) %}
{%- set days = ((('now'|date('U')) - (datetime|date('U'))) / 86400)|round(0, 'floor') -%}
{%- if days <= 0 -%}heute{%- elseif days == 1 -%}vor 1 Tag{%- else -%}vor {{ days }} Tagen{%- endif -%}
{% endmacro %}

{# IdeaListRow (Figma 74:87) — Vote-Control + Titel/Excerpt/Meta + rechte ConsensusBar + ›.
   Vote-Control ist außerhalb des Anker-Tags (valides HTML: kein form/link in <a>).
   is_authenticated: true → vote_form mit my_vote-Zustand; false → vote_anon (Login-Link).
   csrf_token + is_authenticated werden vom Board-Home-Template durchgereicht. #}
{% macro idea_row(idea, board_slug, csrf_token = '', is_authenticated = false) %}
{% import _self as ui %}
<div class="vp-row">
    {% if is_authenticated %}
        {{ ui.vote_form(idea.score_cache, board_slug, idea.id, csrf_token, '', idea.my_vote|default('none')) }}
    {% else %}
        {{ ui.vote_anon(idea.score_cache, board_slug, idea.id) }}
    {% endif %}
    <a class="vp-row-inner" href="/{{ board_slug }}/ideas/{{ idea.id }}">
        <div class="vp-row-content">
            <h2 class="vp-row-title">{{ idea.title }}</h2>
            {% if idea.body %}<p class="vp-row-excerpt">{{ idea.body }}</p>{% endif %}
            <div class="vp-row-meta">
                {{ ui.status_badge(idea.status) }}
                <span class="vp-meta-txt">{{ idea.comment_count|default(0) }} Kommentare</span>
                <span class="vp-meta-txt">·</span>
                <span class="vp-meta-txt">{{ ui.ago(idea.created_at) }}</span>
            </div>
        </div>
        {% set _tot = (idea.up_count|default(0)) + (idea.down_count|default(0)) %}
        {% if _tot > 0 %}
        <div class="vp-row-stats">{{ ui.consensus_bar(((idea.up_count / _tot) * 100)|round) }}</div>
        {% endif %}
        <span class="vp-row-chev" aria-hidden="true">›</span>
    </a>
</div>
{% endmacro %}

{# FeaturedIdeaCard (Figma 69:85) — links Top-Idee (leading Vote), rechts Stats-Bento.
   Vote-Control außerhalb des Anker-Tags (valides HTML). is_authenticated steuert
   vote_form vs. vote_anon analog zur idea_row. #}
{% macro featured_card(idea, board_slug, stats, csrf_token = '', is_authenticated = false) %}
{% import _self as ui %}
<div class="vp-feat">
    <div class="vp-feat-card">
        {% if is_authenticated %}
            {{ ui.vote_form(idea.score_cache, board_slug, idea.id, csrf_token, '', idea.my_vote|default('none')) }}
        {% else %}
            {{ ui.vote_anon(idea.score_cache, board_slug, idea.id) }}
        {% endif %}
        <a class="vp-feat-inner" href="/{{ board_slug }}/ideas/{{ idea.id }}">
            <div class="vp-feat-content">
                <p class="vp-feat-eyebrow">TOP-IDEE</p>
                <h2 class="vp-feat-title">{{ idea.title }}</h2>
                {% if idea.body %}<p class="vp-feat-desc">{{ idea.body }}</p>{% endif %}
                <div class="vp-feat-meta">
                    {{ ui.status_badge(idea.status) }}
                    <span class="vp-meta-txt">{{ idea.comment_count|default(0) }} Kommentare</span>
                    {% set _tot = (idea.up_count|default(0)) + (idea.down_count|default(0)) %}
                    {% if _tot > 0 %}{{ ui.consensus_bar(((idea.up_count / _tot) * 100)|round) }}{% endif %}
                </div>
            </div>
        </a>
    </div>
    {% if stats is defined and stats %}
    <aside class="vp-bento">
        <p class="vp-bento-label">ÜBERSICHT</p>
        <div class="vp-bento-stat"><p class="vp-bento-num">{{ stats.votes_total }}</p><p class="vp-bento-cap">Stimmen gesamt</p></div>
        <div class="vp-bento-stat"><p class="vp-bento-num">{{ stats.ideas_total }}</p><p class="vp-bento-cap">Ideen</p></div>
        <div class="vp-bento-stat"><p class="vp-bento-num vp-bento-num--green">{{ stats.consensus_avg }}%</p><p class="vp-bento-cap">Ø Konsens</p></div>
    </aside>
    {% endif %}
</div>
{% endmacro %}

{# Filter-Chips (Figma 81:64) — Status-Filter; aktiver Chip = Brand-Primary.
   active_sort: wird in alle Filter-Links durchgereicht, damit Sort-Auswahl erhalten bleibt. #}
{% macro filter_chips(board_slug, active_status, active_sort) %}
{% set labels = {'open':'Offen','planned':'Geplant','in_progress':'In Arbeit','done':'Erledigt','declined':'Abgelehnt'} %}
{% set _sort = active_sort|default('newest') %}
{% set _sort_qs = _sort != 'newest' ? '?sort=' ~ _sort : '' %}
<nav class="vp-chips" aria-label="Status-Filter">
    <a class="vp-chip{{ active_status is null ? ' vp-chip--active' : '' }}" href="/{{ board_slug }}{{ _sort_qs }}">Alle</a>
    {% for s in ['open','planned','in_progress','done','declined'] %}
    {% set _sep = _sort_qs != '' ? '&amp;' : '?' %}
    <a class="vp-chip{{ active_status == s ? ' vp-chip--active' : '' }}" href="/{{ board_slug }}{{ _sort_qs }}{{ _sep }}status={{ s }}">{{ labels[s] }}</a>
    {% endfor %}
</nav>
{% endmacro %}

{# SortTabs (Figma 67:45) — Top / Neu / Umstritten.
   board_slug: Board-Slug für den Link-Pfad.
   active_sort: aktive Sortierachse ('newest' | 'top'); steuert vp-sorttab--active.
   active_status: aktueller Status-Filter (wird in Links durchgereicht, null = kein Filter).
   page: aktuelle Seite (wird in Links zurückgesetzt auf 1 beim Sort-Wechsel).
   „Umstritten" bleibt inaktiv — kein ?sort=controversial (Backlog laut PRD). #}
{% macro sort_tabs(board_slug, active_sort, active_status, page) %}
{% set _sort = active_sort|default('newest') %}
{% set _base = '/' ~ board_slug ~ '?' %}
{% set _status_qs = active_status is not null ? '&amp;status=' ~ active_status : '' %}
<div class="vp-sorttabs">
    <a class="vp-sorttab{{ _sort == 'top' ? ' vp-sorttab--active' : '' }}" href="{{ _base }}sort=top{{ _status_qs }}">Top</a>
    <a class="vp-sorttab{{ _sort == 'newest' or _sort is not defined ? ' vp-sorttab--active' : '' }}" href="{{ _base }}sort=newest{{ _status_qs }}">Neu</a>
    <span class="vp-sorttab" aria-disabled="true" title="Folgt in einem späteren Sprint">Umstritten</span>
</div>
{% endmacro %}
