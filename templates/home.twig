{% extends 'base.twig' %}

{% block title %}{{ title|default('Votepit') }}{% endblock %}

{% block styles %}
.vp-wrap--wide { max-width: 640px; }
.vp-accent-dot {
    display: inline-block;
    width: 10px;
    height: 10px;
    border-radius: 999px;
    background: var(--vp-primary);
    margin-right: .5rem;
    vertical-align: middle;
}
.vp-badge-ok {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    background: var(--vp-vote-up-bg);
    color: var(--vp-vote-up);
    border: 1px solid var(--vp-vote-up);
    border-radius: 999px;
    padding: .35rem .85rem;
    font-size: .85rem;
    font-weight: 600;
}
{% endblock %}

{% block body %}
<main class="vp-wrap vp-wrap--wide">
    {% block content %}
    <section class="vp-card">
        <h1 class="vp-h1" style="font-size: 1.75rem;">
            <span class="vp-accent-dot" aria-hidden="true"></span>{{ title }}
        </h1>
        <p class="vp-lead">Selbst-gehostetes Feature-Voting-Board mit Up- &amp; Down-Votes.</p>
        <span class="vp-badge-ok">● {{ status }}</span>
        {% if csrf_token is defined and csrf_token %}
        <form method="post" action="/logout" style="margin-top:1.5rem;">
            <input type="hidden" name="_csrf" value="{{ csrf_token }}">
            <button type="submit" class="vp-btn" style="width:auto;padding:.45rem 1.25rem;">Abmelden</button>
        </form>
        {% endif %}
    </section>
    {% endblock %}
    {% block footer %}
    <footer class="vp-footer">
        Votepit · <a class="vp-link" href="https://github.com/silvio-l/Votepit">GitHub</a>
    </footer>
    {% endblock %}
</main>
{% endblock %}
