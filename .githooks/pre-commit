#!/usr/bin/env bash
#
# Votepit — pre-commit Hook (OSS-Allowlist-Guard)
#
# Blockt jeden Commit, der Pfade enthält, die nicht in .ossallowlist stehen.
# Defense in Depth: erste Schicht ist .gitignore, diese zweite Schicht fängt
# `git add -f` (force) und versehentliches Stagen ab. Interne Doku/Planung
# gehört nach .scratch/ (gitignored) — niemals ins öffentliche Repo.
#
# Aktivierung: `git config core.hooksPath .githooks` (pro Clone).
# Umgehen mit `git commit --no-verify` → dann greift pre-push als dritte Schicht.
#
# Bash-3.2-kompatibel (macOS /bin/bash) — kein mapfile/readarray.
#
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
ALLOWLIST="$ROOT/.ossallowlist"

if [ ! -f "$ALLOWLIST" ]; then
  echo "pre-commit: WARN — keine .ossallowlist gefunden, Guard inaktiv." >&2
  exit 0
fi

# Allowlist einlesen (Kommentar-/Leerzeilen raus).
ALLOWED=()
while IFS= read -r line; do
  case "$line" in
    ''|\#*) continue ;;
  esac
  ALLOWED+=("$line")
done < "$ALLOWLIST"

is_allowed() {
  local p="$1" a
  for a in "${ALLOWED[@]}"; do
    [ "$p" = "$a" ] && return 0
    case "$a" in
      */) [[ "$p" == "$a"* ]] && return 0 ;;
    esac
  done
  return 1
}

violations=()
while IFS= read -r p; do
  [ -z "$p" ] && continue
  if ! is_allowed "$p"; then
    violations+=("$p")
  fi
done < <(git diff --cached --name-only --diff-filter=ACM)

if [ ${#violations[@]} -gt 0 ]; then
  echo "" >&2
  echo "BLOCKIERT durch .ossallowlist — nicht-öffentliche Pfade im Commit:" >&2
  printf '  - %s\n' "${violations[@]}" >&2
  echo "" >&2
  echo "Interne Doku/Planung gehört nach .scratch/ (gitignored)." >&2
  echo "Öffentlich erlaubte Pfade stehen in .ossallowlist." >&2
  echo "Bei bewusster Ausnahme: .ossallowlist erweitern (nach Review)." >&2
  echo "" >&2
  exit 1
fi

# Doc-Gate (zweite Prüfung): Internas/Infra-Leaks, Sprache, Security-Werbung,
# Identität, Platzhalter in den öffentlichen Inhalten dieses Commits.
bash "$ROOT/.githooks/check-docs.sh" staged || exit 1

# Biome lint on staged frontend files (fast gate; Knip + Semgrep run on pre-push).
# Checks .ts/.tsx/.js/.mjs/.json under app/, web/, packages/ — skips cleanly if none staged.
# Bash-3.2-kompatibel — kein mapfile/readarray.
_biome_bin="$ROOT/app/node_modules/.bin/biome"
if [ ! -x "$_biome_bin" ]; then
  _biome_bin="$(command -v biome 2>/dev/null || true)"
fi

if [ -x "$_biome_bin" ]; then
  for _ws_dir in app web packages/ui; do
    _ws_files=()
    while IFS= read -r _p; do
      [ -n "$_p" ] && _ws_files+=("${_p#${_ws_dir}/}")
    done < <(git diff --cached --name-only --diff-filter=ACM \
               | grep -E "^${_ws_dir}/.*\.(ts|tsx|js|mjs|json)$" \
               || true)
    if [ ${#_ws_files[@]} -gt 0 ]; then
      echo "pre-commit: Biome (${_ws_dir}/): ${#_ws_files[@]} file(s)"
      ( cd "$ROOT/$_ws_dir" && "$_biome_bin" check --no-errors-on-unmatched "${_ws_files[@]}" ) \
        || exit 1
    fi
  done
fi

exit 0
