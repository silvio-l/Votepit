# Votepit — SMTP-Test-Konfiguration (Vorlage)
# --------------------------------------------------------------------------
# Kopieren:   cp config/smtp-test.env.example config/smtp-test.env
# Ausführen:  set -a; source config/smtp-test.env; set +a
#             php bin/send-test-mail.php deine@adresse.de
#
# config/smtp-test.env ist gitignored — niemals Secrets einchecken.
# Es wird EXAKT derselbe Mailer wie im Magic-Link-Versand benutzt → Erfolg
# hier beweist den Produktiv-Pfad.
# ==========================================================================

# ── Variante A: Lokaler Beweis ohne echten Provider (Mailpit-Catcher) ──────
# docker run -d --name votepit-mailpit -p 1025:1025 -p 8025:8025 \
#   public.ecr.aws/supabase/mailpit
# Web-UI der gefangenen Mails: http://localhost:8025
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_ENCRYPTION=          # leer = keine Verschlüsselung (nur lokal!)
SMTP_FROM_EMAIL=noreply@votepit.test
SMTP_FROM_NAME=Votepit

# ── Variante B: Microsoft Outlook (persönliches outlook.com-Konto) ─────────
# Voraussetzung: 2FA am Microsoft-Konto AN + ein App-Kennwort erzeugt unter
# account.microsoft.com → Sicherheit → Erweiterte Sicherheitsoptionen →
# App-Kennwörter. Das App-Kennwort (NICHT das normale Passwort) als SMTP_PASS.
# SMTP_HOST=smtp-mail.outlook.com
# SMTP_PORT=587
# SMTP_USER=deine@outlook.com
# SMTP_PASS=<app-kennwort>
# SMTP_ENCRYPTION=tls        # STARTTLS auf 587
# SMTP_FROM_EMAIL=deine@outlook.com   # muss = SMTP_USER sein (Outlook erzwingt das)
# SMTP_FROM_NAME=Votepit

# ── Variante C: Microsoft 365 (Business / eigene Domain) ───────────────────
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_USER=du@deinefirma.de
# SMTP_PASS=<app-kennwort solange Basic-Auth aktiv>
# SMTP_ENCRYPTION=tls
# SMTP_FROM_EMAIL=du@deinefirma.de
# SMTP_FROM_NAME=Votepit
#
# ⚠ WICHTIG (Recherche-Stand 06/2026): Microsoft schaltet Basic-Auth für
# SMTP AUTH (App-Kennwörter) schrittweise ab — Beginn 30.04.2026, endgültig
# Ende 2026. Danach ist für smtp.office365.com OAuth2 (XOAUTH2, Azure-App-
# Registrierung) Pflicht. Für Produktion langfristig daher entweder OAuth2
# ODER ein Versand-Provider (Brevo/Mailgun/Postmark/SMTP2GO) bzw. der SMTP
# des eigenen Hosters. Genau dafür ist die SMTP-Konfig provider-neutral.

# ── Variante D: SMTPS (Port 465, implizites TLS) ───────────────────────────
# SMTP_PORT=465
# SMTP_ENCRYPTION=ssl
