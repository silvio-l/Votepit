{
    "name": "silvio-l/votepit",
    "description": "Selbst-gehostetes Feature-Voting-Board mit Up-/Down-Votes für klassisches PHP/MySQL-Shared-Hosting — ohne Docker, Multi-Board, Magic-Link-Auth.",
    "type": "project",
    "license": "MIT",
    "keywords": ["feedback", "feature-voting", "upvote", "downvote", "self-hosted", "php", "mysql"],
    "require": {
        "php": ">=8.2",
        "ext-pdo": "*",
        "ext-mbstring": "*",
        "ext-intl": "*",
        "slim/slim": "^4.13",
        "slim/psr7": "^1.6",
        "symfony/validator": "^7.0",
        "symfony/mailer": "^7.0",
        "doctrine/dbal": "^4.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.95",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^2.2",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^11.0",
        "rector/rector": "^2.5"
    },
    "autoload": {
        "psr-4": {
            "Votepit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Votepit\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "platform": {
            "php": "8.2"
        },
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    },
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse --memory-limit=512M",
        "cs": "php-cs-fixer fix --dry-run --diff",
        "cs:fix": "php-cs-fixer fix",
        "rector": "rector process --dry-run",
        "rector:fix": "rector process",
        "qa": [
            "@cs",
            "@stan",
            "@rector",
            "@test"
        ]
    }
}
