{
    "name": "silvio-l/votepit",
    "description": "Selbst-gehostetes Feature-Voting-Board mit Up-/Down-Votes für klassisches PHP/MySQL-Shared-Hosting — ohne Docker, Multi-Board, Magic-Link-Auth.",
    "type": "project",
    "license": "MIT",
    "keywords": ["feedback", "feature-voting", "upvote", "downvote", "self-hosted", "php", "mysql"],
    "require": {
        "php": ">=8.2",
        "ext-pdo": "*",
        "ext-mbstring": "*",
        "ext-intl": "*",
        "slim/slim": "^4.13",
        "slim/psr7": "^1.6",
        "slim/csrf": "^1.4",
        "slim/twig-view": "^3.4",
        "twig/twig": "^3.10",
        "symfony/validator": "^7.0",
        "symfony/mailer": "^7.0",
        "doctrine/dbal": "^4.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Votepit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Votepit\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "platform": {
            "php": "8.2"
        }
    }
}
