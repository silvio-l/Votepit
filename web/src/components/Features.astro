---
interface Props {
  t: any;
}
const { t } = Astro.props;
const f = t.features;

// Minimal-Icons (Stroke via currentColor), 1 pro Feature in fester Reihenfolge.
const icons = [
  // 1 Down-Votes — Up/Down-Pfeile
  '<path d="M8 9l4-4 4 4M8 15l4 4 4-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>',
  // 2 Webspace — Server-Stapel
  '<rect x="4" y="4" width="16" height="6" rx="2" stroke="currentColor" stroke-width="2" fill="none"/><rect x="4" y="14" width="16" height="6" rx="2" stroke="currentColor" stroke-width="2" fill="none"/><circle cx="8" cy="7" r="1" fill="currentColor"/><circle cx="8" cy="17" r="1" fill="currentColor"/>',
  // 3 MIT/frei — offenes Schloss
  '<rect x="5" y="11" width="14" height="9" rx="2" stroke="currentColor" stroke-width="2" fill="none"/><path d="M8 11V8a4 4 0 0 1 7.5-2" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none"/>',
  // 4 Multi-Board — Raster
  '<rect x="4" y="4" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="2" fill="none"/><rect x="13" y="4" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="2" fill="none"/><rect x="4" y="13" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="2" fill="none"/><rect x="13" y="13" width="7" height="7" rx="1.5" stroke="currentColor" stroke-width="2" fill="none"/>',
  // 5 Passwortlos — Magic-Link/Brief mit Funke
  '<rect x="3" y="6" width="14" height="11" rx="2" stroke="currentColor" stroke-width="2" fill="none"/><path d="M3.5 7l6.5 5 6.5-5" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round"/><path d="M19 3v4M21 5h-4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>',
  // 6 Agentenbereit — Terminal
  '<rect x="3" y="4" width="18" height="16" rx="2.5" stroke="currentColor" stroke-width="2" fill="none"/><path d="M7 9l3 3-3 3M13 15h4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>',
];
---
<section class="vp-features" aria-labelledby="vp-features-h">
  <h2 class="vp-features-h" id="vp-features-h">{f.heading}</h2>
  <div class="vp-feature-grid">
    {f.items.map((it: any, idx: number) => (
      <article class="vp-feature">
        <span class="vp-feature-ico"><svg width="26" height="26" viewBox="0 0 24 24" aria-hidden="true" set:html={icons[idx]} /></span>
        <h3 class="vp-feature-t">{it.title}</h3>
        <p class="vp-feature-x">{it.text}</p>
      </article>
    ))}
  </div>
</section>
