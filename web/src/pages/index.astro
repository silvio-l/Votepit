---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import SignatureCard from '../components/SignatureCard';
import Features from '../components/Features.astro';
import InstallBlock from '../components/InstallBlock';
import Footer from '../components/Footer.astro';
import { en as t } from '../i18n/en';
const repo = 'https://github.com/silvio-l/votepit';
---
<Base title={t.meta.title} description={t.meta.description} lang="en" canonicalURL="https://votepit.com/">
  <div class="vp-page">
    <Header lang="en" t={t} repo={repo} />

    <main class="vp-hero">
      <div class="vp-hero-inner">
        <h1 class="vp-tagline vp-reveal vp-reveal-2">{t.hero.tagline}</h1>
        <p class="vp-sub vp-reveal vp-reveal-3">{t.hero.sub}</p>
        <a class="vp-cta vp-reveal vp-reveal-3" href={repo} rel="noopener noreferrer">{t.hero.cta}</a>

        <SignatureCard client:load t={t} />
      </div>
    </main>

    <Features t={t} />
    <InstallBlock client:load t={t} />
    <Footer t={t} repo={repo} lang="en" />
  </div>
</Base>
