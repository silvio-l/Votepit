---
import '../styles/tokens.css';
import BrandBackdrop from '../components/BrandBackdrop.astro';

interface Props {
  title: string;
  description: string;
  lang: 'de' | 'en';
  canonicalURL?: string;
  altEn?: string;
  altDe?: string;
}

const { title, description, lang, canonicalURL, altEn = '/', altDe = '/de/' } = Astro.props;
---
<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  {canonicalURL && <link rel="canonical" href={canonicalURL} />}

  <!-- Favicons -->
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="icon" href="/favicon-32.png" sizes="32x32" type="image/png" />
  <link rel="icon" href="/favicon-16.png" sizes="16x16" type="image/png" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

  <!-- Hreflang alternates -->
  <link rel="alternate" hreflang="en" href={`https://votepit.com${altEn}`} />
  <link rel="alternate" hreflang="de" href={`https://votepit.com${altDe}`} />
  <link rel="alternate" hreflang="x-default" href={`https://votepit.com${altEn}`} />
</head>
<body>
  <BrandBackdrop />
  <slot />
</body>
</html>

<style is:global>
  /* Page-level layout */
  .vp-page {
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    position: relative;
    z-index: 1;
  }

  .vp-header {
    padding: 1.25rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 72rem;
    margin: 0 auto;
    width: 100%;
  }

  .vp-nav-link {
    font-family: var(--vp-font-sans);
    font-size: .9rem;
    font-weight: 600;
    color: var(--vp-text);
    text-decoration: none;
    padding: .4rem .8rem;
    border: 1px solid var(--vp-border);
    border-radius: var(--vp-radius-sm);
    transition: background .15s;
  }
  .vp-nav-link:hover { background: rgba(15,23,42,.05); }

  .vp-nav-right { display: flex; align-items: center; gap: .6rem; }

  /* Language switcher — Segmented-Control (gleiche Optik wie die Produkt-Tabs) */
  .vp-lang {
    display: inline-flex;
    padding: 3px;
    gap: 2px;
    background: rgba(15,23,42,.05);
    border: 1px solid var(--vp-border);
    border-radius: var(--vp-radius-sm);
  }
  .vp-lang-opt {
    font-family: var(--vp-font-sans);
    font-size: .8rem;
    font-weight: 600;
    line-height: 1;
    color: var(--vp-text-muted);
    text-decoration: none;
    padding: .35rem .6rem;
    border-radius: 7px;
    transition: color .15s, background .15s, box-shadow .15s;
  }
  .vp-lang-opt:hover { color: var(--vp-text); }
  .vp-lang-opt[aria-current="true"] {
    color: var(--vp-text);
    background: #fff;
    box-shadow: 0 1px 2px rgba(15,23,42,.12);
  }

  /* Hero */
  .vp-hero {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: clamp(2.5rem, 6vw, 5rem) 1.25rem clamp(3.5rem, 8vw, 6rem);
  }
  .vp-hero-inner { width: 100%; max-width: 44rem; min-width: 0; }

  .vp-tagline {
    font-family: var(--vp-font-head);
    font-weight: 800;
    font-size: clamp(1.5rem, 7vw, 4rem);
    line-height: 1.05;
    letter-spacing: -.03em;
    color: var(--vp-text);
    margin: 0 0 1rem;
    overflow-wrap: break-word;
    text-wrap: balance;
  }

  .vp-sub {
    font-size: clamp(1rem, 2.4vw, 1.2rem);
    color: var(--vp-text-muted);
    margin: 0 auto 2.25rem;
    max-width: 34rem;
    line-height: 1.6;
    text-wrap: pretty;
  }

  .vp-cta {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    padding: .8rem 1.9rem;
    background: var(--vp-primary);
    color: var(--vp-primary-contrast);
    border-radius: var(--vp-radius-sm);
    font-family: var(--vp-font-sans);
    font-weight: 600;
    font-size: 1rem;
    text-decoration: none;
    transition: opacity .15s, transform .15s;
  }
  .vp-cta:hover { opacity: .9; transform: translateY(-1px); }

  /* Signature — Up/Down-Vote-Control (das einprägsame Element der Seite) */
  .vp-signature { margin: clamp(3rem, 8vw, 4.5rem) auto 0; max-width: 26rem; }
  .vp-sigcard {
    position: relative;
    display: flex; align-items: center; gap: 1.1rem; text-align: left;
    padding: 1.1rem 1.35rem;
    background: var(--vp-surface);
    border: 1px solid var(--vp-surface-border);
    border-radius: var(--vp-radius);
    box-shadow: 0 0 0 1px var(--vp-border), 0 10px 30px -12px var(--vp-primary-glow);
    backdrop-filter: blur(14px) saturate(1.2);
    -webkit-backdrop-filter: blur(14px) saturate(1.2);
    transition: box-shadow .2s ease, transform .2s ease;
  }
  .vp-sigcard:hover {
    transform: translateY(-2px);
    box-shadow: 0 0 0 1px var(--vp-border), 0 18px 40px -16px var(--vp-primary-glow);
  }
  /* Up/Down-Vote-Control — 1:1 zur Produktkomponente (Board-Frame) */
  .vp-vote {
    display: flex; flex-direction: column; align-items: center; gap: .4rem;
    flex: none;
  }
  .vp-vbtn {
    display: flex; align-items: center; justify-content: center;
    inline-size: 3.1rem; block-size: 2.05rem;
    border-radius: 12px;
    font-size: .8rem; line-height: 1;
    background: #f1f1ee;
    border: 1px solid var(--vp-border);
    color: var(--vp-text-muted);
    cursor: pointer;
    appearance: none; -webkit-appearance: none;
    font-family: inherit; padding: 0;
    transition: transform .16s ease, background .16s ease, box-shadow .16s ease, color .16s ease;
  }
  .vp-vbtn:hover { color: var(--vp-text); transform: translateY(-1px); }
  .vp-vbtn:active { transform: scale(.92); }
  .vp-vbtn--up:hover { color: var(--vp-vote-up); }
  .vp-vbtn--down:hover { color: var(--vp-vote-down); }
  .vp-vbtn--up.is-active, .vp-vbtn--up.is-active:hover {
    background: var(--vp-vote-up); border-color: transparent; color: #fff;
    box-shadow: 0 7px 16px -8px var(--vp-vote-up);
  }
  .vp-vbtn--down.is-active, .vp-vbtn--down.is-active:hover {
    background: var(--vp-vote-down); border-color: transparent; color: #fff;
    box-shadow: 0 7px 16px -8px var(--vp-vote-down);
  }
  .vp-score {
    font-family: var(--vp-font-mono); font-weight: 600; font-size: 1.35rem;
    color: var(--vp-text); font-variant-numeric: tabular-nums; line-height: 1;
    transition: color .16s ease, transform .18s ease;
  }
  .vp-score.is-ticking { transform: scale(1.16); }
  .vp-score--neg { color: var(--vp-vote-down); }
  .vp-sigbody { min-width: 0; flex: 1; }
  .vp-eyebrow {
    margin: 0 0 .3rem; font-family: var(--vp-font-sans); font-weight: 600;
    font-size: .68rem; letter-spacing: .08em; text-transform: uppercase;
    color: var(--vp-vote-up);
  }
  .vp-sigtitle {
    margin: 0 0 .55rem; font-family: var(--vp-font-head); font-weight: 800;
    font-size: 1.05rem; color: var(--vp-text); letter-spacing: -.01em;
  }
  .vp-consensus { display: flex; align-items: center; gap: .6rem; }
  .vp-bar { flex: 1; block-size: 6px; border-radius: 999px; background: var(--vp-vote-up-bg); overflow: hidden; transition: background .3s ease; }
  .vp-bar > i { display: block; block-size: 100%; inline-size: var(--vp-fill, 92%); background: var(--vp-vote-up); border-radius: 999px; transition: inline-size .45s cubic-bezier(.2,.7,.3,1), background .3s ease; }
  .vp-bar.is-low { background: var(--vp-vote-down-bg); }
  .vp-bar.is-low > i { background: var(--vp-vote-down); }
  .vp-pct { flex: none; font-size: .8rem; color: var(--vp-text-muted); font-family: var(--vp-font-mono); }
  .vp-pct strong { color: var(--vp-vote-up); font-weight: 600; }
  .vp-pct.is-low strong { color: var(--vp-vote-down); }
  .vp-status {
    margin: .6rem 0 0; display: flex; align-items: center; gap: .4rem;
    font-size: .78rem; color: var(--vp-text-muted);
  }
  .vp-dot { inline-size: 7px; block-size: 7px; border-radius: 50%; flex: none; }
  .vp-dot--progress { background: var(--vp-status-in-progress); }
  .vp-sigcaption {
    margin: 1rem auto 0; max-width: 24rem;
    font-size: .85rem; color: var(--vp-text-muted); line-height: 1.55; text-wrap: pretty;
  }

  /* Vote-Feedback: Toast + Partikel */
  .vp-toast {
    position: absolute; top: -.7rem; right: .9rem;
    padding: .25rem .6rem; border-radius: 999px;
    background: var(--vp-primary); color: var(--vp-primary-contrast);
    font-family: var(--vp-font-sans); font-size: .72rem; font-weight: 600;
    white-space: nowrap; pointer-events: none;
    opacity: 0; box-shadow: 0 6px 18px -8px var(--vp-primary-glow);
  }
  .vp-toast.is-on { opacity: 1; }
  .vp-particle {
    position: absolute; inline-size: 9px; block-size: 9px;
    font-size: 14px; line-height: 1; pointer-events: none;
    will-change: transform, opacity; z-index: 2;
  }
  .vp-sr {
    position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap; border: 0;
  }

  /* Mini-Animationen — nur ohne reduced-motion-Präferenz (Default-State bleibt sichtbar) */
  @media (prefers-reduced-motion: no-preference) {
    .vp-reveal { opacity: 0; animation: vp-rise .65s cubic-bezier(.2,.7,.3,1) both; }
    .vp-reveal-1 { animation-delay: .04s; }
    .vp-reveal-2 { animation-delay: .12s; }
    .vp-reveal-3 { animation-delay: .20s; }
    .vp-reveal-4 { animation-delay: .30s; }
    @keyframes vp-rise { from { opacity: 0; transform: translateY(14px); } to { opacity: 1; transform: none; } }

    .vp-bar > i { animation: vp-fill 1.1s cubic-bezier(.2,.7,.3,1) .35s both; }
    @keyframes vp-fill { from { inline-size: 0; } to { inline-size: var(--vp-fill, 92%); } }

    .vp-hint { animation: vp-hint 1.1s ease-in-out 2; }
    @keyframes vp-hint {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-3px); box-shadow: 0 8px 16px -8px var(--vp-vote-up); }
    }

    .vp-toast.is-on { animation: vp-toast 1.9s ease forwards; }
    @keyframes vp-toast {
      0% { opacity: 0; transform: translateY(5px) scale(.96); }
      12% { opacity: 1; transform: none; }
      78% { opacity: 1; }
      100% { opacity: 0; transform: translateY(-5px); }
    }
  }

  /* Install — kopierbare Schnellbefehle */
  .vp-install {
    max-width: 40rem;
    margin: 0 auto;
    padding: clamp(1rem, 4vw, 2rem) 1.25rem clamp(2.5rem, 6vw, 4rem);
    text-align: center;
  }
  .vp-install-h {
    font-family: var(--vp-font-head); font-weight: 800;
    font-size: clamp(1.3rem, 3.5vw, 1.8rem); letter-spacing: -.02em;
    color: var(--vp-text); margin: 0 0 .4rem;
  }
  .vp-install-sub { color: var(--vp-text-muted); margin: 0 0 1.5rem; font-size: .98rem; }
  .vp-cmd { text-align: left; }
  .vp-cmd-label {
    display: block; font-size: .72rem; font-weight: 600; letter-spacing: .06em;
    text-transform: uppercase; color: var(--vp-text-muted); margin: 0 0 .5rem;
  }
  .vp-cmd-row {
    display: flex; align-items: stretch; gap: .5rem;
    background: var(--vp-primary); border-radius: var(--vp-radius-sm);
    padding: .5rem .5rem .5rem .9rem;
    box-shadow: 0 14px 34px -18px var(--vp-primary-glow);
  }
  .vp-cmd-code {
    flex: 1; min-width: 0; align-self: center;
    font-family: var(--vp-font-mono); font-size: .86rem; color: #e9e9e7;
    overflow-x: auto; white-space: nowrap;
  }
  .vp-cmd-prompt { color: var(--vp-vote-up); user-select: none; margin-right: .5rem; }
  .vp-cmd-copy {
    flex: none; cursor: pointer; appearance: none; -webkit-appearance: none; border: 0;
    font-family: var(--vp-font-sans); font-size: .8rem; font-weight: 600;
    color: var(--vp-primary); background: #fff; border-radius: 7px;
    padding: .45rem .85rem; transition: background .15s, color .15s;
  }
  .vp-cmd-copy:hover { background: #f1f1ee; }
  .vp-cmd-copy.is-copied { background: var(--vp-vote-up); color: #fff; }
  .vp-install-ftp {
    margin: 1.1rem 0 0; font-size: .88rem; color: var(--vp-text-muted);
    line-height: 1.55; text-wrap: pretty;
  }
  .vp-install-ftp strong { color: var(--vp-text); }

  /* GitHub-Buttons mit Octocat-Icon — Icon + Text immer auf einer Zeile */
  .vp-nav-gh, .vp-foot-gh { display: inline-flex; align-items: center; gap: .4rem; white-space: nowrap; }
  .vp-nav-gh svg, .vp-foot-gh svg { flex: none; }
  @media (max-width: 460px) {
    .vp-gh-text { display: none; }
    .vp-nav-gh { padding-inline: .5rem; }
  }

  /* Feature-Grid */
  .vp-features { max-width: 64rem; margin: 0 auto; padding: clamp(2rem, 6vw, 4.5rem) 1.25rem; }
  .vp-features-h {
    text-align: center; font-family: var(--vp-font-head); font-weight: 800;
    font-size: clamp(1.5rem, 4vw, 2.2rem); letter-spacing: -.02em; color: var(--vp-text); margin: 0 0 2rem;
  }
  .vp-feature-grid { display: grid; grid-template-columns: 1fr; gap: 1rem; }
  @media (min-width: 560px) { .vp-feature-grid { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 900px) { .vp-feature-grid { grid-template-columns: 1fr 1fr 1fr; } }
  .vp-feature {
    background: var(--vp-surface); border: 1px solid var(--vp-surface-border);
    border-radius: var(--vp-radius); padding: 1.4rem;
    box-shadow: 0 0 0 1px var(--vp-border), 0 10px 30px -18px var(--vp-primary-glow);
    backdrop-filter: blur(14px) saturate(1.2); -webkit-backdrop-filter: blur(14px) saturate(1.2);
    transition: transform .2s ease, box-shadow .2s ease;
  }
  .vp-feature:hover { transform: translateY(-3px); box-shadow: 0 0 0 1px var(--vp-border), 0 18px 42px -22px var(--vp-primary-glow); }
  .vp-feature-ico { display: inline-flex; color: var(--vp-vote-up); margin-bottom: .7rem; }
  .vp-feature-t {
    font-family: var(--vp-font-head); font-weight: 800; font-size: 1.05rem;
    letter-spacing: -.01em; color: var(--vp-text); margin: 0 0 .4rem;
  }
  .vp-feature-x { font-size: .92rem; color: var(--vp-text-muted); line-height: 1.55; margin: 0; text-wrap: pretty; }

  /* Docs-Seite */
  .vp-docs { max-width: 44rem; width: 100%; margin: 0 auto; flex: 1; padding: clamp(1.5rem, 5vw, 3rem) 1.25rem clamp(2.5rem, 6vw, 4rem); }
  .vp-docs-h {
    font-family: var(--vp-font-head); font-weight: 800; font-size: clamp(1.8rem, 5vw, 2.6rem);
    letter-spacing: -.02em; color: var(--vp-text); margin: 0 0 .6rem;
  }
  .vp-docs-intro { color: var(--vp-text-muted); font-size: 1.05rem; line-height: 1.6; margin: 0 0 2rem; text-wrap: pretty; }
  .vp-docs-sec { margin: 0 0 1.6rem; }
  .vp-docs-sec h2 { font-family: var(--vp-font-head); font-weight: 800; font-size: 1.15rem; color: var(--vp-text); margin: 0 0 .4rem; }
  .vp-docs-sec p { color: var(--vp-text-muted); line-height: 1.65; margin: 0; text-wrap: pretty; }
  .vp-docs-cta { margin-top: 1rem; }

  /* Footer */
  .vp-site-footer {
    padding: 1.75rem 1.5rem;
    text-align: center;
    font-size: .85rem;
    color: var(--vp-text-muted);
    border-top: 1px solid var(--vp-border);
    display: flex;
    flex-direction: column;
    gap: .35rem;
  }
  .vp-foot-author { margin: 0; }
  .vp-foot-meta { margin: 0; display: inline-flex; gap: .5rem; justify-content: center; align-items: center; flex-wrap: wrap; }
  .vp-foot-sep { color: var(--vp-border); }
  .vp-foot-link { color: var(--vp-text); font-weight: 600; text-decoration: none; border-bottom: 1px solid var(--vp-border); }
  .vp-foot-link:hover { color: var(--vp-vote-down); border-color: currentColor; }
</style>
